POSTGRES_USER=fermier
POSTGRES_PASSWORD=fermier_dev
POSTGRES_DB=fermier_pro
POSTGRES_PORT=5432

API_PORT=3000

# Feature flags (API GET /api/v1/config/client) — true/false, 1/0, yes/no
# Si false : routes REST du module concerné -> 503 (voir guards Nest).
# FEATURE_MARKETPLACE=true
# FEATURE_CHAT=true
# FEATURE_VET_CONSULTATIONS=true
# FEATURE_TASKS=true
# FEATURE_FINANCE=true
# FEATURE_HOUSING=true
# FEATURE_FEED_STOCK=true
# FEATURE_WALLET=true

# Rate limiting (@nestjs/throttler) — plusieurs instances API : definir REDIS_URL
# Ex. redis://localhost:6379  ou  rediss://... (TLS) sur hebergeur cloud
REDIS_URL=
# Optionnel (ms / nombre de requetes par fenetre ; defaut 60000 / 200)
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=200
# Derriere reverse proxy : activer pour que la limite s'applique a l'IP client (X-Forwarded-For)
# TRUST_PROXY=true

# Supabase Auth (verification JWT cote API)
SUPABASE_URL=https://<project-ref>.supabase.co
# Jetons Google/SMS : verifies via JWKS (ES256) avec SUPABASE_URL — pas le « Key ID » du dashboard.
# SUPABASE_JWT_SECRET : optionnel, HS256 uniquement pour tests e2e locaux (pas le kid ES256).
SUPABASE_JWT_SECRET=
# Requis en production pour reçus PDF marketplace, rapports PDF et suppression Auth.
# Dashboard Supabase → Settings → API → service_role (secret, jamais côté mobile).
SUPABASE_SERVICE_ROLE_KEY=

# Optionnel : anciens secrets si tu ajoutes plus tard un JWT maison
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# Supabase Postgres (remote)
# Runtime API : pooler transactionnel (6543) souvent OK pour Nest + Prisma Client.
# Example :
# postgresql://postgres.<ref>:<pwd>@...pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_URL=
# Connexion directe Postgres (port 5432) — requis par schema.prisma (`directUrl`).
# Supabase : URL session/directe (pas le pooler 6543). En local Docker, reprendre DATABASE_URL.
# DIRECT_URL=postgresql://fermier:fermier_dev@127.0.0.1:5432/fermier_pro
DIRECT_URL=
# Optionnel : uniquement pour `npm run prisma:*`. Si db push/migrate semble bloque sur le pooler,
# ajoute l URL session / directe port 5432 (Dashboard Supabase → Database).
# PRISMA_DATABASE_URL=
# Optionnel : hote Postgres local (defaut 127.0.0.1 si tu utilises le fallback POSTGRES_*)
# POSTGRES_HOST=127.0.0.1

# Recommandations IA (Gemini) — côté API uniquement, jamais dans le bundle mobile
# GEMINI_API_KEY=
# Modèle (défaut gemini-2.5-flash-lite — quota gratuit plus généreux que 2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash-lite
# Pause des appels IA après quota dépassé (ms, défaut 900000 = 15 min)
# GEMINI_QUOTA_COOLDOWN_MS=900000

# Support mobile (fallback si non renseigné dans le SaaS admin → Paramètres)
# SUPPORT_PHONE=+221771234567
# SUPPORT_TELEGRAM_URL=https://t.me/fermierpro

# Environnement de déploiement (staging | production). Sur Railway, laisser vide ou
# staging tant que le gateway mobile money simulé est utilisé (MOBILE_MONEY_PROVIDER=dev).
# APP_ENV=staging
# MOBILE_MONEY_PROVIDER=dev
# MOBILE_MONEY_WEBHOOK_SECRET=

# GeniusPay (mobile money réel) — MOBILE_MONEY_PROVIDER=geniuspay
# Dashboard GeniusPay → Paramètres → API (clés sandbox pk_/sk_ ou live)
# GENIUSPAY_API_KEY=pk_sandbox_...
# GENIUSPAY_API_SECRET=sk_sandbox_...
# GENIUSPAY_WEBHOOK_SECRET=whsec_sandbox_...
# Webhook URL à enregistrer chez GeniusPay : POST https://<api>/api/v1/webhooks/geniuspay
# Optionnel : redirections après checkout
# GENIUSPAY_SUCCESS_URL=
# GENIUSPAY_ERROR_URL=
# GENIUSPAY_API_BASE_URL=https://geniuspay.ci/api/v1/merchant
# Alternative doc GeniusPay : https://pay.genius.ci/api/v1/merchant
# Payouts (retrait wallet, versement vendeur, remboursement MM) :
# GENIUSPAY_PAYOUT_WALLET_ID=uuid-du-wallet-payout
# GENIUSPAY_PAYOUT_PROVIDER=   # optionnel : wave, orange_money… (vide = auto PawaPay)

# Yellika SMS (OTP téléphone via hook Supabase Send SMS)
# Doc officielle : https://panel.yellikasms.com/developers/docs
# YELLIKA_SMS_API_TOKEN=
# YELLIKA_SMS_SENDER_ID=
# URL POST exacte Yellika (copier depuis la doc, sans modification) :
# YELLIKA_SMS_SEND_URL=https://panel.yellikasms.com/api/v3/sms/send
# Alias accepté : YELLIKA_SMS_API_BASE_URL (même valeur complète)
# YELLIKA_SMS_APP_NAME=Fermier Pro
# Modèle OTP validé chez Yellika ({{otp}} = code). Obligatoire si le sender exige un texte enregistré :
# YELLIKA_SMS_OTP_TEMPLATE=SolutionIT : votre code est {{otp}}
# SMS rappels abonnement commerçant (false = log uniquement, utile sans crédit Yellika)
# MERCHANT_SUBSCRIPTION_SMS_ENABLED=true
# Secret du hook Supabase Authentication → Hooks → Send SMS (format v1,whsec_...)
# SUPABASE_SEND_SMS_HOOK_SECRET=v1,whsec_...
# Webhook Supabase : POST https://<api>/api/v1/webhooks/supabase/send-sms
# Vérification : GET https://<api>/api/v1/health → phoneAuth.ready === true

# Optional explicit fields if needed by tools/scripts
DB_HOST=
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres
DB_SSL=true
