POSTGRES_USER=fermier
POSTGRES_PASSWORD=fermier_dev
POSTGRES_DB=fermier_pro
POSTGRES_PORT=5432

API_PORT=3000

# Feature flags (API GET /api/v1/config/client) — true/false, 1/0, yes/no
# Si false : routes REST du module concerné -> 503 (voir guards Nest).
# FEATURE_MARKETPLACE=true
# FEATURE_CHAT=true
# FEATURE_VET_CONSULTATIONS=true
# FEATURE_TASKS=true
# FEATURE_FINANCE=true
# FEATURE_HOUSING=true
# FEATURE_FEED_STOCK=true

# Rate limiting (@nestjs/throttler) — plusieurs instances API : definir REDIS_URL
# Ex. redis://localhost:6379  ou  rediss://... (TLS) sur hebergeur cloud
REDIS_URL=
# Optionnel (ms / nombre de requetes par fenetre ; defaut 60000 / 200)
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=200
# Derriere reverse proxy : activer pour que la limite s'applique a l'IP client (X-Forwarded-For)
# TRUST_PROXY=true

# Supabase Auth (verification JWT cote API)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_SECRET=

# Optionnel : anciens secrets si tu ajoutes plus tard un JWT maison
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# Supabase Postgres (remote)
# Runtime API : pooler transactionnel (6543) souvent OK pour Nest + Prisma Client.
# Example :
# postgresql://postgres.<ref>:<pwd>@...pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_URL=
# Optionnel : uniquement pour `npm run prisma:*`. Si db push/migrate semble bloque sur le pooler,
# ajoute l URL session / directe port 5432 (Dashboard Supabase → Database).
# PRISMA_DATABASE_URL=
# Optionnel : hote Postgres local (defaut 127.0.0.1 si tu utilises le fallback POSTGRES_*)
# POSTGRES_HOST=127.0.0.1

# Optional explicit fields if needed by tools/scripts
DB_HOST=
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres
DB_SSL=true
