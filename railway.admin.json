{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "apps/admin-platform/**",
      "packages/types/**",
      "packages/ui/**",
      "railway.admin.json",
      "package.json",
      "package-lock.json"
    ],
    "buildCommand": "echo \"[railway-admin-build] GIT_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo unknown)\" && npm install --ignore-scripts --include=dev && npm run build:admin"
  },
  "deploy": {
    "startCommand": "node apps/admin-platform/scripts/start-admin.cjs",
    "healthcheckPath": "/fr/login",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE",
    "sleepApplication": false,
    "numReplicas": 1
  }
}
