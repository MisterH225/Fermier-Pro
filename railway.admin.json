{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "apps/admin-platform/**",
      "packages/types/**",
      "packages/ui/**",
      "railway.admin.json",
      "package.json",
      "package-lock.json"
    ],
    "buildCommand": "npm install --ignore-scripts && npm run build:admin"
  },
  "deploy": {
    "startCommand": "npm run start --workspace @fermier/admin-platform",
    "healthcheckPath": "/fr/login",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE"
  }
}
