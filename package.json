{
  "name": "fermier-pro",
  "private": true,
  "version": "0.1.0",
  "description": "Fermier Pro monorepo (mobile + api + shared packages)",
  "overrides": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/platform-socket.io": "11.1.19",
    "@nestjs/websockets": "11.1.19",
    "@nestjs/microservices": "11.1.19"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm run start --workspace @fermier/mobile",
    "dev:api": "npm run start:dev --workspace @fermier/api",
    "build:api": "npm run build --workspace @fermier/api",
    "lint:api": "npm run lint --workspace @fermier/api",
    "typecheck:mobile": "npm run typecheck --workspace @fermier/mobile",
    "test:e2e": "npm run test:e2e --workspace @fermier/api"
  },
  "devDependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19"
  }
}
