{
  "name": "fermier-pro",
  "private": true,
  "version": "0.1.0",
  "description": "Fermier Pro monorepo (mobile + api + shared packages)",
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma"
  },
  "overrides": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/platform-socket.io": "11.1.19",
    "@nestjs/websockets": "11.1.19",
    "@nestjs/microservices": "11.1.19"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prisma:generate": "npm run prisma:generate --workspace @fermier/api",
    "build": "npm run build --workspace @fermier/types && npm run build --workspace @fermier/phone && npm run build --workspace @fermier/api",
    "start": "npm run start --workspace @fermier/api",
    "dev:mobile": "npx expo start apps/mobile",
    "expo:start": "npx expo start apps/mobile",
    "dev:api": "npm run start:dev --workspace @fermier/api",
    "dev:admin": "npm run dev --workspace @fermier/admin-platform",
    "build:phone": "npm run build --workspace @fermier/phone",
    "build:api": "npm run build --workspace @fermier/types && npm run build --workspace @fermier/phone && npm run build --workspace @fermier/api",
    "build:admin": "npm run build --workspace @fermier/admin-platform",
    "lint:api": "npm run lint --workspace @fermier/api",
    "typecheck:mobile": "npm run typecheck --workspace @fermier/mobile",
    "typecheck:admin": "npm run typecheck --workspace @fermier/admin-platform",
    "test:e2e": "npm run test:e2e --workspace @fermier/api",
    "test:unit": "npm run test:unit --workspace @fermier/api",
    "ci:quality": "npm run prisma:generate && npm run lint:api && npm run build:api && npm run test:unit && npm run typecheck:mobile && npm run typecheck:admin",
    "ota:preview": "bash scripts/ota-preview.sh",
    "ota:production": "bash scripts/ota-production.sh"
  },
  "devDependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/platform-socket.io": "11.1.19",
    "@nestjs/websockets": "11.1.19",
    "rxjs": "^7.8.1"
  }
}
