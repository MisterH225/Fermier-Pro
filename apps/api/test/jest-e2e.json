{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": "..",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "moduleFileExtensions": ["ts", "js", "json"],
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.e2e.json"
      }
    ]
  },
  "setupFiles": ["<rootDir>/test/load-test-env.ts"],
  "testTimeout": 240000,
  "moduleNameMapper": {
    "^jose$": "<rootDir>/test/mocks/jose.mock.ts",
    "^@fermier/phone$": "<rootDir>/../../packages/phone/src/index.ts"
  }
}
