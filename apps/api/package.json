{
  "name": "@fermier/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node scripts/start-prod.cjs",
    "start:dev": "node scripts/start-dev.cjs",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:unit": "jest --config ./test/jest-unit.json",
    "prisma:generate": "node scripts/prisma-run.cjs generate",
    "prisma:migrate:dev": "node scripts/prisma-run.cjs migrate dev",
    "prisma:migrate:deploy": "node scripts/prisma-run.cjs migrate deploy",
    "prisma:railway-predeploy": "node scripts/railway-predeploy.cjs",
    "prisma:migrate:resolve": "node scripts/prisma-run.cjs migrate resolve",
    "prisma:migrate:status": "node scripts/prisma-run.cjs migrate status",
    "prisma:push": "node scripts/prisma-run.cjs db push",
    "prisma:push:force": "node scripts/prisma-run.cjs db push --accept-data-loss",
    "prisma:seed": "node prisma/seed.cjs",
    "backfill:farm-departments": "node -r ts-node/register/transpile-only scripts/backfill-farm-departments.ts",
    "backfill:region-stats": "node -r ts-node/register/transpile-only scripts/backfill-region-stats.ts",
    "promote:superadmin": "node scripts/promote-superadmin.cjs",
    "set:auth-password": "node scripts/set-auth-password.cjs"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fermier/phone": "*",
    "@fermier/types": "*",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/client": "^5.18.0",
    "@sentry/nestjs": "^10.65.0",
    "@sentry/profiling-node": "^10.65.0",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "archiver": "^7.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "papaparse": "^5.5.4",
    "pdfkit": "^0.15.2",
    "pdfmake": "^0.2.20",
    "prisma": "^5.18.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "standardwebhooks": "^1.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/archiver": "^6.0.4",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.14.11",
    "@types/papaparse": "^5.5.2",
    "@types/pdfkit": "^0.13.9",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
