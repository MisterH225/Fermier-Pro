  wallet
}

enum PigPriceSnapshotSource {
  listing
  direct_sale
}

/// Catégorie d’annonce porc sur le Market (porcelets, reproducteurs, etc.).
enum ListingMarketCategory {
  piglet
  breeder
  butcher
  reformed
}

/// Poids vif ou carcasse pour le poids indiqué sur l'annonce.
enum ListingWeightBasis {
  live
  carcass
}

model MarketplaceListing {
  id            String          @id @default(cuid())
  sellerUserId  String
  seller        User            @relation("ListingSeller", fields: [sellerUserId], references: [id], onDelete: Restrict)
  farmId        String?
  farm          Farm?           @relation(fields: [farmId], references: [id], onDelete: SetNull)
  animalId      String?
  animal        Animal?         @relation(fields: [animalId], references: [id], onDelete: SetNull)
  /// Catégorie métier (affiche filtres Market). Optionnel pour annonces historiques.
  category      ListingMarketCategory?
  /// URLs photos (Supabase Storage ou autre), ordre d’affichage = ordre du tableau.
  photoUrls     Json            @default("[]")
  /// Identifiants animaux concernés (lien cheptel) ; `animalId` peut rester le principal pour compat.
  animalIds     Json            @default("[]")
  totalWeightKg Decimal?        @db.Decimal(14, 4)
  /// Poids vif ou carcasse associé à `totalWeightKg`.
  weightBasis   ListingWeightBasis?
  /// Prix au kg demandé par le vendeur (prioritaire sur `unitPrice` pour le flux porc).
  pricePerKg    Decimal?        @db.Decimal(14, 4)
  /// Prix total calculé ou saisi ; affichage principal grille Market.
  totalPrice    Decimal?        @db.Decimal(14, 2)
  breedLabel    String?
  title         String
  description   String?
  unitPrice     Decimal?        @db.Decimal(14, 2)
  quantity      Int?
  currency      String          @default("XOF")
  locationLabel String?
  /// Résumé sanitaire figé ou surchargé à la publication (JSON côté API).
  healthSummary Json?
  status        ListingStatus   @default(draft)
  publishedAt   DateTime?
  expiresAt     DateTime?
  viewsCount    Int             @default(0)
  consultationsCount Int      @default(0)
  /// Rendez-vous de retrait des animaux (convenu hors paiement in-app).
  pickupAt      DateTime?
  pickupNote    String?
  /// Nombre d'offres avec fonds sécurisés (PAYMENT_HELD+).
  activeOfferCount Int             @default(0)
  /// Vendeur accepte les offres à crédit (charcutier uniquement).
  creditEnabled   Boolean          @default(false)
  /// Acheteur retenu après acceptation d'offre (escrow).
  reservedForBuyerUserId String?
  reservedForBuyer       User?    @relation("ListingReservedBuyer", fields: [reservedForBuyerUserId], references: [id], onDelete: SetNull)
  shippedAt     DateTime?
  deliveredAt   DateTime?
  disputedAt    DateTime?
  createdAt     DateTime        @default(now())
  archived      Boolean         @default(false)
  updatedAt     DateTime        @updatedAt
  offers        MarketplaceOffer[]
  transactions  MarketplaceTransaction[]
  deliveryDisputes MarketplaceDeliveryDispute[]
  creditArbitrations MarketplaceCreditArbitration[]
  favorites     BuyerFavorite[]
  chatRooms     ChatRoom[]

  @@index([sellerUserId])
  @@index([status])
  @@index([farmId])
  @@index([category])
}

enum FeedTypeUnit {
  kg
  tonne
  sac
}

/// Phase de production cible d'un aliment (affectation coûts par bande).
enum FeedProductionPhase {
  sous_mere
  transition
  starter
  growth
  fattening
  breeder
  unknown
}

enum FeedMovementKind {
  in
  stock_check
}

/// Type d'aliment (croissance, démarrage, etc.) — paramètres et stock agrégé ferme.
model FeedType {
  id                    String        @id @default(cuid())
  farmId                String
  farm                  Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name                  String
  unit                  FeedTypeUnit  @default(kg)
  /// Seuil bas (jours de stock restant) pour alertes personnalisées (défaut 15 jours côté métier UI).
  lowStockThresholdDays Int           @default(15)
  color                 String        @default("#5d7a1f")
  /// Poids d'un sac (kg), requis pour saisie en sacs / contrôles inventaire.
  weightPerBagKg        Decimal?      @db.Decimal(12, 4)
  /// Dernier inventaire sacs restants (après dernier contrôle).
  bagCountCurrent       Decimal?      @db.Decimal(14, 4)
  lastCheckDate         DateTime?
  /// Stock courant agrégé (kg).
  currentStockKg        Decimal       @default(0) @db.Decimal(14, 4)
  /// Prix unitaire moyen pondéré (kg) — mois en cours, entrées avec coût.
  currentPumpPrice      Decimal?      @db.Decimal(14, 4)
  /// Phase de production (démarrage, transition, etc.) pour affectation coûts par bande.
  productionPhase       FeedProductionPhase @default(unknown)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  movements             FeedStockMovement[]

  @@index([farmId])
}

/// Entrées et contrôles de stock (consommation dérivée des inventaires).
model FeedStockMovement {
  id                   String           @id @default(cuid())
  farmId               String
  farm                 Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  feedTypeId           String
  feedType             FeedType         @relation(fields: [feedTypeId], references: [id], onDelete: Cascade)
  kind                 FeedMovementKind
  /// Quantité saisie à l'enregistrement (sacs, kg ou tonnes selon `quantityUnit`).
  quantityInput        Decimal?         @db.Decimal(14, 4)
  /// Unité de saisie à l'enregistrement (`kg`, `sac`, `tonne`).
  quantityUnit         FeedTypeUnit?
  /// Base du prix unitaire enregistré (`kg` ou `sac`).
  priceBasis           String?
  /// Quantité ajoutée (kg) pour une entrée `in`.
  quantityKg           Decimal?         @db.Decimal(14, 4)
  bagsCounted          Decimal?         @db.Decimal(14, 4)
  bagsConsumed         Decimal?         @db.Decimal(14, 4)
  daysSinceLastCheck   Int?
  dailyConsumptionKg   Decimal?         @db.Decimal(14, 6)
  stockAfterKg         Decimal          @db.Decimal(14, 4)
  supplier             String?
  unitPrice            Decimal?         @db.Decimal(14, 2)
  /// Coût total de l'entrée (devise ferme).
  totalCost            Decimal?         @db.Decimal(14, 2)
  notes                String?
  occurredAt           DateTime         @default(now())
  linkedExpenseId      String?
  isCostMissing        Boolean          @default(false)
  reconciliationDismissedAt DateTime?
  createdByUserId      String
  creator              User             @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt            DateTime         @default(now())
  reconciliationRejections FeedReconciliationRejection[]

  @@index([farmId, occurredAt])
  @@index([feedTypeId, occurredAt])
  @@index([farmId, isCostMissing])
}

/// Paires stock ↔ finance déjà rejetées par l'utilisateur.
model FeedReconciliationRejection {
  id              String            @id @default(cuid())
  farmId          String
  farm            Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  movementId      String
  movement        FeedStockMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  expenseId       String
  rejectedAt      DateTime          @default(now())
  rejectedByUserId String
  rejector        User              @relation(fields: [rejectedByUserId], references: [id], onDelete: Restrict)

  @@unique([movementId, expenseId])
  @@index([farmId])
}

model MarketplaceOffer {
  id           String             @id @default(cuid())
  listingId    String
  listing      MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerUserId  String
  buyer        User               @relation("OfferBuyer", fields: [buyerUserId], references: [id], onDelete: Restrict)
  buyerFarmId  String?
  offerType    OfferType          @default(standard)
  /// Prix / kg proposé par l’acheteur (si renseigné, `offeredPrice` = total de l’offre).
  proposedPricePerKg Decimal?   @db.Decimal(14, 4)
  offeredPrice Decimal            @db.Decimal(14, 2)
  quantity     Int?
  message      String?
  /// Contre-proposition vendeur : prix / kg.
  counterPricePerKg Decimal?     @db.Decimal(14, 4)
  /// Vente à crédit — % avance (20–50).
  advancePercentage   Int?
  advanceAmount       Decimal?    @db.Decimal(14, 2)
  balanceAmount       Decimal?    @db.Decimal(14, 2)
  balanceDueDays      Int?
  balanceDueAt        DateTime?
  deliveredAt         DateTime?
  advancePaidDeclaredAt  DateTime?
  advanceConfirmedAt     DateTime?
  balancePaidDeclaredAt  DateTime?
  balanceConfirmedAt     DateTime?
  advancePaymentMode     String?
  balancePaymentMode     String?
  advancePaymentRef      String?
  balancePaymentRef      String?
  balancePaidAmount      Decimal? @db.Decimal(14, 2)
  status       OfferStatus        @default(pending)
  completedAt  DateTime?
  archived     Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  transaction  MarketplaceTransaction?
  deliveryDisputes MarketplaceDeliveryDispute[]
  creditArbitrations MarketplaceCreditArbitration[]

  @@index([listingId])
  @@index([buyerUserId])
  @@index([listingId, status])
  @@index([offerType, status])
}

enum ReceiptGenerationStatus {
  pending
  generated
  failed
}

/// Transaction marketplace avec escrow (cycle complet jusqu'à clôture).
model MarketplaceTransaction {
  id                      String                       @id @default(cuid())
  offerId                 String                       @unique
  offer                   MarketplaceOffer             @relation(fields: [offerId], references: [id], onDelete: Restrict)
  listingId               String
  listing                 MarketplaceListing           @relation(fields: [listingId], references: [id], onDelete: Restrict)
  buyerUserId             String
  buyer                   User                         @relation("TransactionBuyer", fields: [buyerUserId], references: [id], onDelete: Restrict)
  sellerUserId            String
  seller                  User                         @relation("TransactionSeller", fields: [sellerUserId], references: [id], onDelete: Restrict)
  status                  MarketplaceTransactionStatus @default(PAYMENT_PENDING)
  priceType               MarketplacePriceType
  agreedPricePerKg        Decimal?                     @db.Decimal(14, 4)
  agreedFlatPrice         Decimal?                     @db.Decimal(14, 2)
  estimatedWeightKg       Decimal?                     @db.Decimal(14, 4)
  blockedAmount           Decimal                      @db.Decimal(14, 2)
  finalAmount             Decimal?                     @db.Decimal(14, 2)
  realWeightKg            Decimal?                     @db.Decimal(14, 4)
  arbitrationWeightKg     Decimal?                     @db.Decimal(14, 4)
  weightDeclaredByBuyerAt DateTime?
  weightDisputeOpenedAt   DateTime?
  weightValidatedAt       DateTime?
  weightValidatedBy       WeightValidatedBy?
  weightScalePhotoUrl     String?
  pickupDate              DateTime?                    @db.Date
  pickupLocation          String?
  sellerShippedAt         DateTime?
  shipmentMethod          MarketplaceShipmentMethod?
  shipmentNotes           String?
  buyerReceivedAt         DateTime?
  receiptCondition        MarketplaceReceiptCondition?
  receiptNotes            String?
  receivedAnimalIds       Json                         @default("[]")
  commissionRate          Decimal                      @db.Decimal(5, 4)
  commissionAmount        Decimal?                     @db.Decimal(14, 2)
  sellerReceivedAmount    Decimal?                     @db.Decimal(14, 2)
  buyerRefundAmount       Decimal?                     @db.Decimal(14, 2)
  buyerAdditionalCharge   Decimal?                     @db.Decimal(14, 2)
  paymentProviderRef      String?
  paymentMethod           MarketplacePaymentMethod?
  paymentInitiatedAt      DateTime?
  paymentConfirmedAt      DateTime?
  closedAt                DateTime?
  receiptGenerationStatus ReceiptGenerationStatus @default(pending)
  cancelledAt             DateTime?
  cancelReason            String?
  offerExpiresAt          DateTime
  currency                String                       @default("XOF")
  /// Transaction vente à crédit — pas de clôture escrow avant solde.
  isCredit                Boolean                      @default(false)
  /// Les frais de plateforme sont à la charge de l'acheteur (ajoutés au montant bloqué).
  /// false pour les transactions historiques où la commission était déduite du vendeur.
  buyerPaysCommission     Boolean                      @default(false)
  /// Taux de commission prélevée sur le vendeur à la clôture (0 = aucun).
  sellerCommissionRate    Decimal                      @default(0) @db.Decimal(5, 4)
  /// Montant de commission prélevé sur le vendeur (calculé à la clôture).
  sellerCommissionAmount  Decimal?                     @db.Decimal(14, 2)
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  fundMovements           MarketplaceFundMovement[]
  walletEntries           UserWalletEntry[]
  platformRevenue         PlatformRevenue?
  receipt                 MarketplaceTransactionReceipt?
  deliveryDisputes        MarketplaceDeliveryDispute[]
  pendingTransfers        MarketplacePendingTransfer[]

  @@index([listingId, status])
  @@index([buyerUserId, status])
  @@index([sellerUserId, status])
  @@index([status])
  @@index([offerExpiresAt])
}

/// Litige livraison marketplace (double confirmation).
model MarketplaceDeliveryDispute {
  id              String                         @id @default(cuid())
  listingId       String
  listing         MarketplaceListing             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  offerId         String
  offer           MarketplaceOffer               @relation(fields: [offerId], references: [id], onDelete: Cascade)
  transactionId   String
  transaction     MarketplaceTransaction         @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  raisedByUserId  String
  raisedBy        User                           @relation("DeliveryDisputeRaisedBy", fields: [raisedByUserId], references: [id], onDelete: Restrict)
  disputeType     String
  description     String
  photoUrls       Json                           @default("[]")
  status          MarketplaceDeliveryDisputeStatus @default(open)
  resolvedAt      DateTime?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  @@index([listingId])
  @@index([transactionId])
  @@index([status])
}

/// Transfert cheptel acheteur en attente après clôture transaction.
model MarketplacePendingTransfer {
  id              String                 @id @default(cuid())
  transactionId   String
  transaction     MarketplaceTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  buyerUserId     String
  buyer           User                   @relation("PendingTransferBuyer", fields: [buyerUserId], references: [id], onDelete: Restrict)
  buyerFarmId     String?
  buyerFarm       Farm?                  @relation(fields: [buyerFarmId], references: [id], onDelete: SetNull)
  animalIds       Json                   @default("[]")
  expiresAt       DateTime
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([buyerUserId])
  @@index([transactionId])
  @@index([expiresAt])
}

model MarketplaceFundMovement {
  id            String                      @id @default(cuid())
  transactionId String
  transaction   MarketplaceTransaction      @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  kind          MarketplaceFundMovementKind
  amount        Decimal                     @db.Decimal(14, 2)
  currency      String                      @default("XOF")
  providerRef   String?
  note          String?
  createdAt     DateTime                    @default(now())

  @@index([transactionId])
}

model MarketplaceTransactionReceipt {
  id                   String                 @id @default(cuid())
  receiptNumber        String                 @unique
  transactionId        String                 @unique
  transaction          MarketplaceTransaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  sellerId             String
  seller               User                   @relation("ReceiptSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  buyerId              String
  buyer                User                   @relation("ReceiptBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  pdfStoragePath       String
  pdfSizeBytes         Int
  generatedAt          DateTime               @default(now())
  receiptYear          Int
  yearSequence         Int
  downloadedBySeller   Boolean                @default(false)
  downloadedByBuyer    Boolean                @default(false)
  sellerDownloadedAt   DateTime?
  buyerDownloadedAt    DateTime?

  @@unique([receiptYear, yearSequence])
  @@index([generatedAt(sort: Desc)])
  @@index([sellerId])
  @@index([buyerId])
}

model PlatformRevenue {
  id               String                  @id @default(cuid())
  transactionId    String?                 @unique
  transaction      MarketplaceTransaction? @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  vetAppointmentId String?                 @unique
  vetAppointment   VetAppointment?         @relation(fields: [vetAppointmentId], references: [id], onDelete: Restrict)
  sellerId         String
  buyerId          String
  grossAmount      Decimal                @db.Decimal(14, 2)
  commissionRate   Decimal                @db.Decimal(5, 4)
  commissionAmount Decimal                @db.Decimal(14, 2)
  collectedAt      DateTime               @default(now())
  type             String                 @default("COMMISSION")

  @@index([collectedAt(sort: Desc)])
}

/// Avis acheteur → ferme (notation Market).
model FarmMarketRating {
  id              String   @id @default(cuid())
  farmId          String
  farm            Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  ratedByUserId String
  rater           User     @relation("FarmMarketRatingAuthor", fields: [ratedByUserId], references: [id], onDelete: Cascade)
  score           Int
  comment         String?
  createdAt       DateTime @default(now())

  @@unique([farmId, ratedByUserId])
  @@index([farmId])
}

model AnimalWeight {
  id         String   @id @default(cuid())
  animalId   String
  animal     Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  weightKg   Decimal  @db.Decimal(10, 3)
  measuredAt DateTime @default(now())
  note       String?
  createdAt  DateTime @default(now())

  @@index([animalId, measuredAt])
}

/// Type d'invitation collaborative.
/// - share_link : lien créé par l'owner avec rôle/permissions pré-encodés
///   (cas particulier : `isDefault=true` = lien par défaut généré à la
///   création de la ferme, support du QR code « accès collaboratif »).
/// - scan_request : demande générée quand un utilisateur scanne un lien
///   par défaut ; l'owner doit valider rôle + permissions.
enum FarmInvitationKind {
  share_link
  scan_request
}

enum FarmInvitationStatus {
  pending
  accepted
  rejected
  expired
}

model FarmInvitation {
  id               String                 @id @default(cuid())
  farmId           String
  farm             Farm                   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdById      String
  creator          User                   @relation("InvitationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  /// Null tant que l'owner n'a pas accepté un scan_request ou pour les liens par défaut non encore configurés.
  role             MembershipRole?
  scopes           String[]               @default([])
  token            String                 @unique
  expiresAt        DateTime
  redeemedAt       DateTime?
  redeemedByUserId String?
  inviteeEmail     String?
  inviteePhone     String?
  /// Renseigné quand l'invitation cible un compte existant (recherche par identifiant).
  inviteeUserId    String?
  invitee          User?                  @relation("InvitationInvitee", fields: [inviteeUserId], references: [id], onDelete: SetNull)
  /// Message personnel optionnel saisi par l'inviteur.
  message          String?
  createdAt        DateTime               @default(now())

  kind             FarmInvitationKind     @default(share_link)
  status           FarmInvitationStatus   @default(pending)
  /// Vrai pour le lien collaboratif par défaut (créé à la création de la ferme).
  isDefault        Boolean                @default(false)
  /// Vue UI des permissions ({ readOnly, dataEntry, health, finance }) — alignée sur `scopes`.
  permissions      Json?
  /// Étiquette UI côté mobile (`veterinarian` | `technician` | `partner`).
  recipientKind    String?
  acceptedAt       DateTime?
  rejectedAt       DateTime?
  /// Utilisateur ayant scanné le QR par défaut (uniquement sur kind=scan_request).
  scannedByUserId  String?
  scannedBy        User?                  @relation("InvitationScanner", fields: [scannedByUserId], references: [id], onDelete: SetNull)
  archived         Boolean                @default(false)

  @@index([farmId])
  @@index([expiresAt])
  @@index([farmId, kind, status])
  @@index([farmId, isDefault])
  @@index([inviteeUserId, status])
}

model FarmMembership {
  id          String         @id @default(cuid())
  farmId      String
  userId      String
  role        MembershipRole
  scopes      String[]
  /// Vue UI des permissions ({ readOnly, dataEntry, health, finance }) — alignée sur `scopes`.
  permissions Json?
  invitedAt   DateTime?
  acceptedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  farm        Farm           @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityLogs MemberActivityLog[]
  archived     Boolean             @default(false)

  @@unique([farmId, userId, role])
  @@index([farmId, role])
  @@index([userId, role])
}

enum MemberActivityModule {
  cheptel
  health
  finance
  stock
  gestation
  collaboration
}

model MemberActivityLog {
  id         String               @id @default(cuid())
  farmId     String
  farm       Farm                 @relation(fields: [farmId], references: [id], onDelete: Cascade)
  memberId   String
  member     FarmMembership       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  module     MemberActivityModule
  action     String
  detail     Json?
  createdAt  DateTime             @default(now())

  @@index([farmId, createdAt])
  @@index([farmId, memberId])
}

enum ChatRoomKind {
  farm
  direct
}

enum ChatMessageModificationType {
  phone_masked
  image_blocked
}

enum ChatSecurityEventType {
  phone_masked_in_text
  image_blocked_phone
  alphabetic_phone_attempt
}

model ChatRoom {
  id                    String              @id @default(cuid())
  kind                  ChatRoomKind
  farmId                String?             @unique
  farm                  Farm?               @relation(fields: [farmId], references: [id], onDelete: Cascade)
  directKey             String?             @unique
  title                 String?
  /// Annonce marketplace liée à la négociation (chat acheteur ↔ vendeur).
  marketplaceListingId  String?
  marketplaceListing    MarketplaceListing? @relation(fields: [marketplaceListingId], references: [id], onDelete: SetNull)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  members               ChatRoomMember[]
  messages              ChatMessage[]

  @@index([kind])
  @@index([marketplaceListingId])
}

model ChatRoomMember {
  id         String    @id @default(cuid())
  roomId     String
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  @@unique([roomId, userId])
  @@index([userId])
}

model ChatMessage {
  id               String                        @id @default(cuid())
  roomId           String
  room             ChatRoom                      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderUserId     String
  sender           User                          @relation(fields: [senderUserId], references: [id], onDelete: Restrict)
  body             String
  wasModified      Boolean                       @default(false)
  modificationType ChatMessageModificationType?
  createdAt        DateTime                      @default(now())

  @@index([roomId, createdAt])
}

model ChatSecurityEvent {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  farmId    String?
  farm      Farm?                 @relation(fields: [farmId], references: [id], onDelete: SetNull)
  eventType ChatSecurityEventType
  context   Json?
  createdAt DateTime              @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([farmId])
}

