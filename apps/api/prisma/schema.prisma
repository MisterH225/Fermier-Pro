generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProfileType {
  producer
  technician
  veterinarian
  buyer
}

enum SmartAlertModule {
  stock
  health
  finance
  gestation
  cheptel
  market
}

enum SmartAlertPriority {
  critical
  warning
  info
}

/// Mode de suivi principal a la ferme (reversible ; voir docs/LIVESTOCK_MODES_AND_HOUSING.md).
enum FarmLivestockMode {
  individual
  batch
  hybrid
}

/// Statut du projet (ferme) — actif ou archivé.
enum FarmStatus {
  active
  archived
}

enum MembershipRole {
  owner
  manager
  worker
  veterinarian
  viewer
}

model User {
  id                    String               @id @default(cuid())
  supabaseUserId        String               @unique
  email                 String?              @unique
  fullName              String?
  /// Prénom affiché (accueil, OAuth Google souvent pré-rempli à la création).
  firstName             String?
  /// Nom de famille (OAuth ou saisi).
  lastName              String?
  /// URL publique avatar (ex. Supabase Storage).
  avatarUrl             String?
  /// Libellé ferme sur l’accueil producteur (prioritaire sur la 1re ferme).
  producerHomeFarmName  String?
  homeLatitude          Decimal?             @db.Decimal(10, 7)
  homeLongitude         Decimal?             @db.Decimal(10, 7)
  homeLocationLabel     String?
  /// `gps` | `manual` — origine des coordonnées / libellé lieu.
  homeLocationSource    String?
  phone                 String?              @unique
  isActive              Boolean              @default(true)
  accountStatus         AccountStatus        @default(active)
  suspendedAt           DateTime?
  suspendedReason       String?
  suspendedUntil        DateTime?
  bannedAt              DateTime?
  bannedReason          String?
  /// Préférences notifications push (opt-in ; jetons dans `PushDevice`).
  notificationsEnabled Boolean             @default(false)
  /// Producteur : configuration initiale (projet + cheptel) terminée.
  isOnboarded           Boolean              @default(false)
  /// Producteur : a quitté l’onboarding sans compléter (bannière + états vides).
  onboardingSkipped     Boolean              @default(false)
  /// Acceptation des CGU (obligatoire avant utilisation de l''app).
  cguAcceptedAt         DateTime?
  cguVersionAccepted    String?
  /// Poids du vendeur dans l'indice PigPrice (0.1 nouveaux comptes, ≥0.5 vérifiés).
  indexWeight           Decimal              @default(0.1) @db.Decimal(3, 2)
  /// Ventes marketplace conclues (handover) — anti-manipulation indice.
  completedTransactions Int                  @default(0)
  /// Score réputation marketplace (100 par défaut).
  reputationScore       Int                  @default(100)
  /// Dernière activité API (connexion / requête authentifiée).
  lastActiveAt          DateTime?
  /// Annulations vendeur sur transactions escrow.
  cancelledAsSellerCount Int                 @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  /// Projet (ferme) actif sélectionné par l'utilisateur producteur.
  activeFarmId          String?
  activeFarm            Farm?                @relation("UserActiveFarm", fields: [activeFarmId], references: [id], onDelete: SetNull)
  profiles              Profile[]
  pushDevices           PushDevice[]
  technicianProfile     TechnicianProfile?
  buyerProfile          BuyerProfile?
  userWallet            UserWallet?
  walletEntriesAsCounterparty UserWalletEntry[] @relation("WalletEntryCounterparty")
  withdrawalRequests    WithdrawalRequest[]
  withdrawalReviews     WithdrawalRequest[] @relation("WithdrawalReviewer")
  producerProfile       ProducerProfile?
  reactivationWaitlist  ReactivationWaitlist[]
  memberships           FarmMembership[]
  ownedFarms            Farm[]               @relation("FarmOwner")
  farmInvitesCreated    FarmInvitation[]     @relation("InvitationCreator")
  farmInvitesScanned    FarmInvitation[]     @relation("InvitationScanner")
  farmInvitesReceived   FarmInvitation[]     @relation("InvitationInvitee")
  tasksAssigned         FarmTask[]           @relation("TaskAssignee")
  tasksCreated          FarmTask[]           @relation("TaskCreator")
  tasksCompleted        FarmTask[]           @relation("TaskCompleter")
  taskNotifications     TaskNotification[]
  expensesCreated       FarmExpense[]
  revenuesCreated       FarmRevenue[]
  batchHealthEventsRecorded LivestockBatchHealthEvent[]
  listingsAsSeller      MarketplaceListing[] @relation("ListingSeller")
  listingsReservedAsBuyer MarketplaceListing[] @relation("ListingReservedBuyer")
  offersAsBuyer         MarketplaceOffer[]   @relation("OfferBuyer")
  marketplaceDeliveryDisputesRaised MarketplaceDeliveryDispute[] @relation("DeliveryDisputeRaisedBy")
  marketplacePendingTransfersAsBuyer MarketplacePendingTransfer[] @relation("PendingTransferBuyer")
  creditArbitrationsAsBuyer  MarketplaceCreditArbitration[] @relation("CreditArbitrationBuyer")
  creditArbitrationsAsSeller MarketplaceCreditArbitration[] @relation("CreditArbitrationSeller")
  marketplaceTransactionsAsBuyer  MarketplaceTransaction[] @relation("TransactionBuyer")
  marketplaceTransactionsAsSeller MarketplaceTransaction[] @relation("TransactionSeller")
  marketplaceReceiptsAsSeller     MarketplaceTransactionReceipt[] @relation("ReceiptSeller")
  marketplaceReceiptsAsBuyer      MarketplaceTransactionReceipt[] @relation("ReceiptBuyer")
  vetConsultsOpened     VetConsultation[]    @relation("VetConsultOpenedBy")
  vetConsultsPrimary    VetConsultation[]    @relation("VetConsultPrimaryVet")
  vetConsultAttachments VetConsultationAttachment[]
  penPlacementsCreated PenPlacement[] @relation("PenPlacementCreator")
  penLogsRecorded      PenLog[]       @relation("PenLogRecorder")
  livestockExitsRecorded LivestockExit[]
  feedStockMovementsCreated FeedStockMovement[]
  feedReconciliationRejections FeedReconciliationRejection[]
  livestockStatusLogsRecorded LivestockStatusLog[] @relation("LivestockStatusLogRecorder")
  farmHealthRecordsRecorded FarmHealthRecord[] @relation("FarmHealthRecordRecorder")
  vaccineRecordsAdministered VaccineRecord[] @relation("VaccineRecordAdministeredBy")
  farmMarketRatingsGiven FarmMarketRating[] @relation("FarmMarketRatingAuthor")
  chatRoomMemberships ChatRoomMember[]
  chatMessagesSent    ChatMessage[]
  chatSecurityEvents  ChatSecurityEvent[]
  auditLogs           AuditLog[]
  vetProfile            VetProfile?
  vetRatingsAuthored    VetRating[] @relation("VetRatingAuthor")
  vetAppointmentsAsProducer VetAppointment[] @relation("AppointmentProducer")
  vetAppointmentsAsVet      VetAppointment[] @relation("AppointmentVet")
  superAdmin            SuperAdmin?
  adminAuditActions     AdminAuditLog[]      @relation("AdminAuditActor")
  adminAuditTargets     AdminAuditLog[]      @relation("AdminAuditTarget")
  adminMessagesSent     AdminMessage[]       @relation("AdminMessageSender")
  adminMessagesReceived AdminMessage[]       @relation("AdminMessageRecipient")
  feedStatus            FeedUserStatus       @default(active)
  feedSuspensionUntil   DateTime?
  feedViolationCount    Int                  @default(0)
  feedViolationLastReset DateTime?
  communityFeedPosts    CommunityFeedPost[]
  communityFeedComments CommunityFeedComment[]
  moderationEvents      ModerationEvent[]
  sanctionAppeals       SanctionAppeal[]
  communityFeedReads    CommunityFeedRead[]
  communityFeedLikes    CommunityFeedLike[]

  @@index([email])
  @@index([accountStatus])
  @@index([feedStatus])
  @@index([phone])
  @@index([activeFarmId])
}

enum VetVerificationStatus {
  pending
  verified
  rejected
}

/// Profil professionnel vétérinaire (recherche publique après validation).
model VetProfile {
  id                   String                @id @default(cuid())
  userId               String                @unique
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName             String
  orderNumber          String
  primarySpecialty     String
  otherSpecialties     Json?
  locationCity         String
  locationCountry      String
  professionalPhone    String
  schoolName           String
  schoolCountry        String
  graduationYear       Int
  diplomaPhotoUrl      String
  profilePhotoUrl      String?
  bio                  String?
  availability         Boolean               @default(true)
  interventionRadiusKm Int?
  verificationStatus   VetVerificationStatus @default(pending)
  rejectionReason      String?
  ratingAvg            Decimal?              @db.Decimal(3, 2)
  ratingCount          Int                   @default(0)
  completedAppointments Int                  @default(0)
  cancelledAppointmentsAsVet Int             @default(0)
  verifiedAt           DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ratings              VetRating[]
  vetAppointments      VetAppointment[]
  appointmentRatings   VetAppointmentRating[]

  @@index([verificationStatus])
  @@index([primarySpecialty])
  @@index([locationCountry, locationCity])
}

model VetRating {
  id            String     @id @default(cuid())
  vetId         String
  vet           VetProfile @relation(fields: [vetId], references: [id], onDelete: Cascade)
  ratedByUserId String
  ratedBy       User       @relation("VetRatingAuthor", fields: [ratedByUserId], references: [id], onDelete: Cascade)
  ratedByFarmId String?
  ratedByFarm   Farm?      @relation(fields: [ratedByFarmId], references: [id], onDelete: SetNull)
  score         Int
  comment       String?
  createdAt     DateTime   @default(now())

  @@unique([vetId, ratedByUserId])
  @@index([vetId])
}

/// Jeton Expo push (ou autre) enregistré pour l’utilisateur — un enregistrement par appareil / jeton.
model PushDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Profile {
  id          String      @id @default(cuid())
  userId      String
  type        ProfileType
  displayName String?
  /// Photo de profil propre à ce rôle (producteur, vétérinaire, technicien…).
  avatarUrl   String?
  isDefault   Boolean     @default(false)
  profileStatus ProfileModerationStatus @default(active)
  profileSuspendedReason String?
  profileSuspendedAt     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([profileStatus])
}

model Farm {
  id           String             @id @default(cuid())
  ownerId      String
  name         String
  speciesFocus String             @default("porcin")
  /// Suivi individuel, par bandes uniquement, ou hybride (politiques par categorie).
  livestockMode              FarmLivestockMode @default(individual)
  /// Ex. { "sow": "individual", "finisher": "batch" } — cles metier a stabiliser avec le referentiel categories.
  livestockCategoryPolicies Json?
  /// Parametrage batiments / loges (synthese editable ; detail dans Barn/Pen).
  housingBuildingsCount Int?
  housingPensPerBuilding Int?
  housingMaxPigsPerPen   Int?
  /// Derniers numéros de tag par préfixe (Trui, Ver, Eng, Dem, All).
  lastTruiTagNumber      Int                @default(0)
  lastVerTagNumber       Int                @default(0)
  lastEngTagNumber       Int                @default(0)
  lastDemTagNumber       Int                @default(0)
  lastAllTagNumber       Int                @default(0)
  latitude     Decimal?
  longitude    Decimal?
  address      String?
  capacity     Int?
  /// Statut du projet : actif (visible) ou archivé (masqué par défaut).
  status       FarmStatus         @default(active)
  /// Date d'archivage (si status = archived).
  archivedAt   DateTime?
  /// Ordre d'affichage dans la liste des projets (0 = premier).
  displayOrder Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  owner        User               @relation("FarmOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  /// Utilisateurs ayant ce projet comme projet actif (relation inverse).
  activeFarmUsers User[]          @relation("UserActiveFarm")
  memberships  FarmMembership[]
  invitations  FarmInvitation[]
  activityLogs MemberActivityLog[]
  animals      Animal[]
  livestockStatusLogs LivestockStatusLog[]
  tasks        FarmTask[]
  expenses     FarmExpense[]
  revenues     FarmRevenue[]
  marketplaceListings MarketplaceListing[]
  pigPriceSnapshots   PigPriceSnapshot[]
  vetConsultations    VetConsultation[]
  vetAppointments     VetAppointment[]
  livestockBatches  LivestockBatch[]
  barns             Barn[]
  livestockExits    LivestockExit[] @relation("ExitOriginFarm")
  transfersReceived LivestockExit[] @relation("ExitTransferDestinationFarm")
  chatRoom          ChatRoom?
  chatSecurityEvents ChatSecurityEvent[]
  auditLogs         AuditLog[]
  feedTypes             FeedType[]
  feedStockMovements  FeedStockMovement[]
  feedReconciliationRejections FeedReconciliationRejection[]
  financeSettings   FarmFinanceSettings?
  financeCategories FinanceCategory[]
  farmHealthRecords FarmHealthRecord[]
  customVaccines        StandardVaccine[] @relation("FarmCustomVaccines")
  vaccineRecords        VaccineRecord[]
  vetRatingsReceived    VetRating[]
  marketRatingsReceived FarmMarketRating[]
  smartAlerts          SmartAlert[]
  farmAlertSettings    FarmAlertSettings?
  farmReports          FarmReport[]
  farmBudgets          FarmBudget[]
  farmBudgetSuggestions FarmBudgetSuggestion[]
  gmqSettings              FarmGmqSettings[]
  gestations               Gestation[]
  gestationSettings        GestationSettings?
  profitabilitySettings    FarmProfitabilitySettings?
  farmProfitabilitySnapshots FarmProfitabilitySnapshot[]
  batchProfitabilitySnapshots BatchProfitabilitySnapshot[]
  appSettings              FarmAppSettings?
  marketplacePendingTransfers MarketplacePendingTransfer[]
  predictions              FarmPrediction?

  @@index([ownerId, status])
  @@index([status])
}

/// Préférences app régionales / apparence (par ferme).
model FarmAppSettings {
  id                 String   @id @default(cuid())
  farmId             String   @unique
  farm               Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  language           String   @default("fr")
  dateFormat         String   @default("DD/MM/YYYY")
  timezone           String   @default("Africa/Abidjan")
  theme              String   @default("light")
  budgetAutoSuggest  Boolean  @default(true)
  dailySummaryHour   String?
  /// Toggles notifications étendus (marketplace, chat, IA…) — complète FarmAlertSettings.
  notificationExtra  Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// IC / GMQ référence et prix marché (rentabilité).
model FarmProfitabilitySettings {
  id                 String   @id @default(cuid())
  farmId             String   @unique
  farm               Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  marketPricePerKg   Decimal? @db.Decimal(14, 4)
  icTargetStarter    Decimal  @default(1.8) @db.Decimal(6, 3)
  icTargetGrowth     Decimal  @default(2.8) @db.Decimal(6, 3)
  icTargetFattening  Decimal  @default(3.2) @db.Decimal(6, 3)
  gmqRefStarter      Int      @default(300)
  gmqRefGrowth       Int      @default(450)
  gmqRefFattening    Int      @default(650)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum ProfitabilityBatchStatus {
  open
  closed
}

/// Snapshot global de rentabilité ferme (cache recalculé à chaque événement clé).
model FarmProfitabilitySnapshot {
  id                    String   @id @default(cuid())
  farmId                String
  farm                  Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  period                String
  snapshotDate          DateTime @default(now())
  grossMarginRealized   Decimal  @db.Decimal(16, 2)
  grossMarginPct        Decimal? @db.Decimal(8, 4)
  netMarginRealized     Decimal  @db.Decimal(16, 2)
  netMarginPct          Decimal? @db.Decimal(8, 4)
  costPerKgRealized     Decimal? @db.Decimal(14, 4)
  costPerKgProjected    Decimal? @db.Decimal(14, 4)
  roiRealized           Decimal? @db.Decimal(10, 4)
  roiProjected          Decimal? @db.Decimal(10, 4)
  breakevenPricePerKg   Decimal? @db.Decimal(14, 4)
  revenuesRealized      Decimal  @db.Decimal(16, 2)
  revenuesProjected     Decimal? @db.Decimal(16, 2)
  costsDirectRealized   Decimal  @db.Decimal(16, 2)
  costsIndirectRealized Decimal  @db.Decimal(16, 2)
  costsProjected        Decimal? @db.Decimal(16, 2)
  grossMarginProjected  Decimal? @db.Decimal(16, 2)
  netMarginProjected    Decimal? @db.Decimal(16, 2)
  kgProducedRealized    Decimal? @db.Decimal(14, 4)
  kgProjected           Decimal? @db.Decimal(14, 4)
  marketPricePerKg      Decimal? @db.Decimal(14, 4)
  dataQuality           String   @default("insufficient")
  detailJson            Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([farmId, period])
  @@index([farmId, snapshotDate(sort: Desc)])
}

/// Snapshot rentabilité par bande.
model BatchProfitabilitySnapshot {
  id                    String                   @id @default(cuid())
  farmId                String
  farm                  Farm                     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  batchId               String                   @unique
  batch                 LivestockBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  snapshotDate          DateTime                 @default(now())
  status                ProfitabilityBatchStatus @default(open)
  revenuesRealized      Decimal                  @default(0) @db.Decimal(16, 2)
  revenuesProjected     Decimal?                 @db.Decimal(16, 2)
  costsDirectRealized   Decimal                  @default(0) @db.Decimal(16, 2)
  costsIndirectRealized Decimal                  @default(0) @db.Decimal(16, 2)
  costsProjected        Decimal?                 @db.Decimal(16, 2)
  grossMarginRealized   Decimal                  @default(0) @db.Decimal(16, 2)
  netMarginRealized     Decimal                  @default(0) @db.Decimal(16, 2)
  netMarginPctRealized  Decimal?                 @db.Decimal(8, 4)
  costPerKgRealized     Decimal?                 @db.Decimal(14, 4)
  costPerKgProjected    Decimal?                 @db.Decimal(14, 4)
  roiRealized           Decimal?                 @db.Decimal(10, 4)
  roiProjected          Decimal?                 @db.Decimal(10, 4)
  icActual              Decimal?                 @db.Decimal(8, 4)
  gmqActual             Decimal?                 @db.Decimal(10, 2)
  kgProducedRealized    Decimal?                 @db.Decimal(14, 4)
  kgProjected           Decimal?                 @db.Decimal(14, 4)
  breakevenPricePerKg   Decimal?                 @db.Decimal(14, 4)
  isProfitable          Boolean?
  dataQuality           String                   @default("insufficient")
  detailJson            Json?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([farmId, snapshotDate(sort: Desc)])
}

/// Objectifs GMQ / poids cible par catégorie (ferme).
model FarmGmqSettings {
  id                 String   @id @default(cuid())
  farmId             String
  farm               Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  categoryKey        String
  targetGmqGPerDay   Decimal? @db.Decimal(8, 2)
  targetSaleWeightKg Decimal? @db.Decimal(10, 3)
  alertThresholdGmq  Decimal? @db.Decimal(8, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([farmId, categoryKey])
  @@index([farmId])
}

enum FinanceCategoryType {
  income
  expense
}

/// Paramètres financiers globaux de la ferme (devise, alertes).
model FarmFinanceSettings {
  id                  String   @id @default(cuid())
  farmId              String   @unique
  farm                Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  currencyCode        String   @default("XOF")
  currencySymbol      String   @default("FCFA")
  lowBalanceThreshold Decimal? @db.Decimal(14, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Catégorie de dépense ou de revenu (référentiel par ferme).
model FinanceCategory {
  id        String              @id @default(cuid())
  farmId    String
  farm      Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  type      FinanceCategoryType
  key       String
  name      String
  icon      String?
  isDefault Boolean             @default(false)
  createdAt DateTime            @default(now())
  expenses    FarmExpense[]
  revenues    FarmRevenue[]
  budgetLines FarmBudgetLine[]

  @@unique([farmId, type, key])
  @@index([farmId, type])
}

enum BudgetStatus {
  on_track
  warning
  exceeded
}

enum BudgetCreatedFrom {
  manual
  copied
  auto_suggested
}

enum BudgetLineStatus {
  ok
  warning
  exceeded
}

/// Budget mensuel par ferme (lignes par catégorie de dépense).
model FarmBudget {
  id           String            @id @default(cuid())
  farmId       String
  farm         Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  year         Int
  month        Int
  totalPlanned Decimal           @db.Decimal(14, 2)
  status       BudgetStatus      @default(on_track)
  createdFrom  BudgetCreatedFrom @default(manual)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  lines        FarmBudgetLine[]
  suggestions  FarmBudgetSuggestion[]

  @@unique([farmId, year, month])
  @@index([farmId, year, month])
}

model FarmBudgetLine {
  id            String          @id @default(cuid())
  budgetId      String
  budget        FarmBudget      @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  categoryId    String
  category      FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amountPlanned Decimal         @db.Decimal(14, 2)

  @@unique([budgetId, categoryId])
  @@index([categoryId])
}

model FarmBudgetSuggestion {
  id            String    @id @default(cuid())
  farmId        String
  farm          Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  budgetId      String?
  budget        FarmBudget? @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  type          String
  message       String
  actionPayload Json?
  isApplied     Boolean   @default(false)
  isDismissed   Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@index([farmId, budgetId])
  @@index([farmId, isDismissed, isApplied])
}

/// Journal des changements de statut animal / bande (cheptel).
model LivestockStatusLog {
  id               String   @id @default(cuid())
  farmId           String
  farm             Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  /// `animal` | `batch`
  entityType       String
  entityId         String
  oldStatus        String?
  newStatus        String
  note             String?
  createdAt        DateTime @default(now())
  recordedByUserId String
  recorder         User     @relation("LivestockStatusLogRecorder", fields: [recordedByUserId], references: [id], onDelete: Restrict)

  @@index([farmId, createdAt])
  @@index([entityType, entityId])
}

/// Journal d'audit applicatif (actions sensibles). Voir docs/SECURITY_ARCHITECTURE.md.
model AuditLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  actorUserId  String
  actor        User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  farmId       String?
  farm         Farm?    @relation(fields: [farmId], references: [id], onDelete: SetNull)
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?

  @@index([actorUserId, createdAt])
  @@index([farmId, createdAt])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

enum TaskStatus {
  todo
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  normal
  high
}

enum TaskReminder {
  j_minus_1
  j_zero
  both
}

enum TaskNotificationType {
  assigned
  reminder
  overdue
  escalation
  completed
}

model FarmTask {
  id                String        @id @default(cuid())
  farmId            String
  farm              Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  category          String?
  status            TaskStatus    @default(todo)
  priority          TaskPriority  @default(normal)
  dueAt             DateTime?
  reminder          TaskReminder?
  completedAt       DateTime?
  completedByUserId String?
  completedBy       User?         @relation("TaskCompleter", fields: [completedByUserId], references: [id], onDelete: SetNull)
  assignedUserId    String?
  assignee          User?         @relation("TaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdByUserId   String
  creator           User          @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  animalId          String?
  animal            Animal?       @relation(fields: [animalId], references: [id], onDelete: SetNull)
  createdAt         DateTime      @default(now())
  archived          Boolean       @default(false)
  updatedAt         DateTime      @updatedAt
  notifications     TaskNotification[]

  @@index([farmId, status])
  @@index([farmId, dueAt])
