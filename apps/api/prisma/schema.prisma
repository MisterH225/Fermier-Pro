  fattening
  starter
  nursing
  unknown
}

enum AnimalOrigin {
  farm_born
  purchased
}

enum AnimalHealthStatus {
  healthy
  sick
  recovering
}

/// Version et texte des conditions générales d''utilisation (ligne unique `current`).
model CguSettings {
