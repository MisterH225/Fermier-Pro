generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProfileType {
  producer
  technician
  veterinarian
  buyer
}

enum SmartAlertModule {
  stock
  health
  finance
  gestation
  cheptel
  market
}

enum SmartAlertPriority {
  critical
  warning
  info
}

/// Mode de suivi principal a la ferme (reversible ; voir docs/LIVESTOCK_MODES_AND_HOUSING.md).
enum FarmLivestockMode {
  individual
  batch
  hybrid
}

enum MembershipRole {
  owner
  manager
  worker
  veterinarian
  viewer
}

model User {
  id                    String               @id @default(cuid())
  supabaseUserId        String               @unique
  email                 String?              @unique
  fullName              String?
  /// Prénom affiché (accueil, OAuth Google souvent pré-rempli à la création).
  firstName             String?
  /// Nom de famille (OAuth ou saisi).
  lastName              String?
  /// URL publique avatar (ex. Supabase Storage).
  avatarUrl             String?
  /// Libellé ferme sur l’accueil producteur (prioritaire sur la 1re ferme).
  producerHomeFarmName  String?
  homeLatitude          Decimal?             @db.Decimal(10, 7)
  homeLongitude         Decimal?             @db.Decimal(10, 7)
  homeLocationLabel     String?
  /// `gps` | `manual` — origine des coordonnées / libellé lieu.
  homeLocationSource    String?
  phone                 String?              @unique
  isActive              Boolean              @default(true)
  accountStatus         AccountStatus        @default(active)
  suspendedAt           DateTime?
  suspendedReason       String?
  suspendedUntil        DateTime?
  bannedAt              DateTime?
  bannedReason          String?
  /// Préférences notifications push (opt-in ; jetons dans `PushDevice`).
  notificationsEnabled Boolean             @default(false)
  /// Producteur : configuration initiale (projet + cheptel) terminée.
  isOnboarded           Boolean              @default(false)
  /// Producteur : a quitté l’onboarding sans compléter (bannière + états vides).
  onboardingSkipped     Boolean              @default(false)
  /// Acceptation des CGU (obligatoire avant utilisation de l''app).
  cguAcceptedAt         DateTime?
  cguVersionAccepted    String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  profiles              Profile[]
  pushDevices           PushDevice[]
  memberships           FarmMembership[]
  ownedFarms            Farm[]               @relation("FarmOwner")
  farmInvitesCreated    FarmInvitation[]     @relation("InvitationCreator")
  farmInvitesScanned    FarmInvitation[]     @relation("InvitationScanner")
  tasksAssigned         FarmTask[]           @relation("TaskAssignee")
  tasksCreated          FarmTask[]           @relation("TaskCreator")
  tasksCompleted        FarmTask[]           @relation("TaskCompleter")
  taskNotifications     TaskNotification[]
  expensesCreated       FarmExpense[]
  revenuesCreated       FarmRevenue[]
  batchHealthEventsRecorded LivestockBatchHealthEvent[]
  listingsAsSeller      MarketplaceListing[] @relation("ListingSeller")
  offersAsBuyer         MarketplaceOffer[]   @relation("OfferBuyer")
  vetConsultsOpened     VetConsultation[]    @relation("VetConsultOpenedBy")
  vetConsultsPrimary    VetConsultation[]    @relation("VetConsultPrimaryVet")
  vetConsultAttachments VetConsultationAttachment[]
  penPlacementsCreated PenPlacement[] @relation("PenPlacementCreator")
  penLogsRecorded      PenLog[]       @relation("PenLogRecorder")
  livestockExitsRecorded LivestockExit[]
  feedStockMovementsCreated FeedStockMovement[]
  livestockStatusLogsRecorded LivestockStatusLog[] @relation("LivestockStatusLogRecorder")
  farmHealthRecordsRecorded FarmHealthRecord[] @relation("FarmHealthRecordRecorder")
  vaccineRecordsAdministered VaccineRecord[] @relation("VaccineRecordAdministeredBy")
  farmMarketRatingsGiven FarmMarketRating[] @relation("FarmMarketRatingAuthor")
  chatRoomMemberships ChatRoomMember[]
  chatMessagesSent    ChatMessage[]
  auditLogs           AuditLog[]
  vetProfile            VetProfile?
  vetRatingsAuthored    VetRating[] @relation("VetRatingAuthor")
  superAdmin            SuperAdmin?
  adminAuditActions     AdminAuditLog[]      @relation("AdminAuditActor")
  adminAuditTargets     AdminAuditLog[]      @relation("AdminAuditTarget")
  adminMessagesSent     AdminMessage[]       @relation("AdminMessageSender")
  adminMessagesReceived AdminMessage[]       @relation("AdminMessageRecipient")

  @@index([email])
  @@index([accountStatus])
  @@index([phone])
}

enum VetVerificationStatus {
  pending
  verified
  rejected
}

/// Profil professionnel vétérinaire (recherche publique après validation).
model VetProfile {
  id                   String                @id @default(cuid())
  userId               String                @unique
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName             String
  orderNumber          String
  primarySpecialty     String
  otherSpecialties     Json?
  locationCity         String
  locationCountry      String
  professionalPhone    String
  schoolName           String
  schoolCountry        String
  graduationYear       Int
  diplomaPhotoUrl      String
  profilePhotoUrl      String?
  bio                  String?
  availability         Boolean               @default(true)
  interventionRadiusKm Int?
  verificationStatus   VetVerificationStatus @default(pending)
  rejectionReason      String?
  ratingAvg            Decimal?              @db.Decimal(3, 2)
  ratingCount          Int                   @default(0)
  verifiedAt           DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ratings              VetRating[]

  @@index([verificationStatus])
  @@index([primarySpecialty])
  @@index([locationCountry, locationCity])
}

model VetRating {
  id            String     @id @default(cuid())
  vetId         String
  vet           VetProfile @relation(fields: [vetId], references: [id], onDelete: Cascade)
  ratedByUserId String
  ratedBy       User       @relation("VetRatingAuthor", fields: [ratedByUserId], references: [id], onDelete: Cascade)
  ratedByFarmId String?
  ratedByFarm   Farm?      @relation(fields: [ratedByFarmId], references: [id], onDelete: SetNull)
  score         Int
  comment       String?
  createdAt     DateTime   @default(now())

  @@unique([vetId, ratedByUserId])
  @@index([vetId])
}

/// Jeton Expo push (ou autre) enregistré pour l’utilisateur — un enregistrement par appareil / jeton.
model PushDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Profile {
  id          String      @id @default(cuid())
  userId      String
  type        ProfileType
  displayName String?
  /// Photo de profil propre à ce rôle (producteur, vétérinaire, technicien…).
  avatarUrl   String?
  isDefault   Boolean     @default(false)
  profileStatus ProfileModerationStatus @default(active)
  profileSuspendedReason String?
  profileSuspendedAt     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([profileStatus])
}

model Farm {
  id           String             @id @default(cuid())
  ownerId      String
  name         String
  speciesFocus String             @default("porcin")
  /// Suivi individuel, par bandes uniquement, ou hybride (politiques par categorie).
  livestockMode              FarmLivestockMode @default(individual)
  /// Ex. { "sow": "individual", "finisher": "batch" } — cles metier a stabiliser avec le referentiel categories.
  livestockCategoryPolicies Json?
  /// Parametrage batiments / loges (synthese editable ; detail dans Barn/Pen).
  housingBuildingsCount Int?
  housingPensPerBuilding Int?
  housingMaxPigsPerPen   Int?
  /// Derniers numéros de tag par préfixe (Trui, Ver, Eng, Dem).
  lastTruiTagNumber      Int                @default(0)
  lastVerTagNumber       Int                @default(0)
  lastEngTagNumber       Int                @default(0)
  lastDemTagNumber       Int                @default(0)
  latitude     Decimal?
  longitude    Decimal?
  address      String?
  capacity     Int?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  owner        User               @relation("FarmOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships  FarmMembership[]
  invitations  FarmInvitation[]
  activityLogs MemberActivityLog[]
  animals      Animal[]
  livestockStatusLogs LivestockStatusLog[]
  tasks        FarmTask[]
  expenses     FarmExpense[]
  revenues     FarmRevenue[]
  marketplaceListings MarketplaceListing[]
  vetConsultations    VetConsultation[]
  livestockBatches  LivestockBatch[]
  barns             Barn[]
  livestockExits    LivestockExit[] @relation("ExitOriginFarm")
  transfersReceived LivestockExit[] @relation("ExitTransferDestinationFarm")
  chatRoom          ChatRoom?
  auditLogs         AuditLog[]
  feedTypes             FeedType[]
  feedStockMovements  FeedStockMovement[]
  financeSettings   FarmFinanceSettings?
  financeCategories FinanceCategory[]
  farmHealthRecords FarmHealthRecord[]
  customVaccines        StandardVaccine[] @relation("FarmCustomVaccines")
  vaccineRecords        VaccineRecord[]
  vetRatingsReceived    VetRating[]
  marketRatingsReceived FarmMarketRating[]
  smartAlerts          SmartAlert[]
  farmAlertSettings    FarmAlertSettings?
  farmReports          FarmReport[]
  farmBudgets          FarmBudget[]
  farmBudgetSuggestions FarmBudgetSuggestion[]
  gmqSettings          FarmGmqSettings[]
  gestations           Gestation[]
  gestationSettings    GestationSettings?
}

/// Objectifs GMQ / poids cible par catégorie (ferme).
model FarmGmqSettings {
  id                 String   @id @default(cuid())
  farmId             String
  farm               Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  categoryKey        String
  targetGmqGPerDay   Decimal? @db.Decimal(8, 2)
  targetSaleWeightKg Decimal? @db.Decimal(10, 3)
  alertThresholdGmq  Decimal? @db.Decimal(8, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([farmId, categoryKey])
  @@index([farmId])
}

enum FinanceCategoryType {
  income
  expense
}

/// Paramètres financiers globaux de la ferme (devise, alertes).
model FarmFinanceSettings {
  id                  String   @id @default(cuid())
  farmId              String   @unique
  farm                Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  currencyCode        String   @default("XOF")
  currencySymbol      String   @default("FCFA")
  lowBalanceThreshold Decimal? @db.Decimal(14, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Catégorie de dépense ou de revenu (référentiel par ferme).
model FinanceCategory {
  id        String              @id @default(cuid())
  farmId    String
  farm      Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  type      FinanceCategoryType
  key       String
  name      String
  icon      String?
  isDefault Boolean             @default(false)
  createdAt DateTime            @default(now())
  expenses    FarmExpense[]
  revenues    FarmRevenue[]
  budgetLines FarmBudgetLine[]

  @@unique([farmId, type, key])
  @@index([farmId, type])
}

enum BudgetStatus {
  on_track
  warning
  exceeded
}

enum BudgetCreatedFrom {
  manual
  copied
  auto_suggested
}

enum BudgetLineStatus {
  ok
  warning
  exceeded
}

/// Budget mensuel par ferme (lignes par catégorie de dépense).
model FarmBudget {
  id           String            @id @default(cuid())
  farmId       String
  farm         Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  year         Int
  month        Int
  totalPlanned Decimal           @db.Decimal(14, 2)
  status       BudgetStatus      @default(on_track)
  createdFrom  BudgetCreatedFrom @default(manual)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  lines        FarmBudgetLine[]
  suggestions  FarmBudgetSuggestion[]

  @@unique([farmId, year, month])
  @@index([farmId, year, month])
}

model FarmBudgetLine {
  id            String          @id @default(cuid())
  budgetId      String
  budget        FarmBudget      @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  categoryId    String
  category      FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amountPlanned Decimal         @db.Decimal(14, 2)

  @@unique([budgetId, categoryId])
  @@index([categoryId])
}

model FarmBudgetSuggestion {
  id            String    @id @default(cuid())
  farmId        String
  farm          Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  budgetId      String?
  budget        FarmBudget? @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  type          String
  message       String
  actionPayload Json?
  isApplied     Boolean   @default(false)
  isDismissed   Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@index([farmId, budgetId])
  @@index([farmId, isDismissed, isApplied])
}

/// Journal des changements de statut animal / bande (cheptel).
model LivestockStatusLog {
  id               String   @id @default(cuid())
  farmId           String
  farm             Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  /// `animal` | `batch`
  entityType       String
  entityId         String
  oldStatus        String?
  newStatus        String
  note             String?
  createdAt        DateTime @default(now())
  recordedByUserId String
  recorder         User     @relation("LivestockStatusLogRecorder", fields: [recordedByUserId], references: [id], onDelete: Restrict)

  @@index([farmId, createdAt])
  @@index([entityType, entityId])
}

/// Journal d'audit applicatif (actions sensibles). Voir docs/SECURITY_ARCHITECTURE.md.
model AuditLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  actorUserId  String
  actor        User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  farmId       String?
  farm         Farm?    @relation(fields: [farmId], references: [id], onDelete: SetNull)
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?

  @@index([actorUserId, createdAt])
  @@index([farmId, createdAt])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

enum TaskStatus {
  todo
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  normal
  high
}

enum TaskReminder {
  j_minus_1
  j_zero
  both
}

enum TaskNotificationType {
  assigned
  reminder
  overdue
  escalation
  completed
}

model FarmTask {
  id                String        @id @default(cuid())
  farmId            String
  farm              Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  category          String?
  status            TaskStatus    @default(todo)
  priority          TaskPriority  @default(normal)
  dueAt             DateTime?
  reminder          TaskReminder?
  completedAt       DateTime?
  completedByUserId String?
  completedBy       User?         @relation("TaskCompleter", fields: [completedByUserId], references: [id], onDelete: SetNull)
  assignedUserId    String?
  assignee          User?         @relation("TaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdByUserId   String
  creator           User          @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  animalId          String?
  animal            Animal?       @relation(fields: [animalId], references: [id], onDelete: SetNull)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  notifications     TaskNotification[]

  @@index([farmId, status])
  @@index([farmId, dueAt])
  @@index([assignedUserId])
  @@index([animalId])
}

model TaskNotification {
  id        String               @id @default(cuid())
  taskId    String
  task      FarmTask               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TaskNotificationType
  sentAt    DateTime               @default(now())
  isRead    Boolean                @default(false)

  @@index([taskId, type])
  @@index([userId, isRead])
}

model FarmExpense {
  id                 String            @id @default(cuid())
  farmId             String
  farm               Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  amount             Decimal           @db.Decimal(14, 2)
  currency           String            @default("XOF")
  label              String
  /// Ancien libellé libre ; préférer `financeCategoryId`.
  category           String?
  note               String?
  occurredAt         DateTime          @default(now())
  createdByUserId    String
  creator            User              @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt          DateTime          @default(now())
  financeCategoryId  String?
  financeCategory    FinanceCategory?  @relation(fields: [financeCategoryId], references: [id], onDelete: SetNull)
  linkedEntityType   String?
  linkedEntityId     String?
  attachmentUrl      String?
  healthVetVisitLink HealthVetVisitDetail?
  healthTreatmentLink HealthTreatmentDetail?

  @@index([farmId, occurredAt])
  @@index([financeCategoryId])
}

model FarmRevenue {
  id                 String            @id @default(cuid())
  farmId             String
  farm               Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  amount             Decimal           @db.Decimal(14, 2)
  currency           String            @default("XOF")
  label              String
  category           String?
  note               String?
  occurredAt         DateTime          @default(now())
  createdByUserId    String
  creator            User              @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt          DateTime          @default(now())
  financeCategoryId  String?
  financeCategory    FinanceCategory?  @relation(fields: [financeCategoryId], references: [id], onDelete: SetNull)
  linkedEntityType   String?
  linkedEntityId     String?
  attachmentUrl      String?
  isAutoGenerated    Boolean           @default(false)

  @@index([farmId, occurredAt])
  @@index([financeCategoryId])
}

enum HealthSeverity {
  info
  watch
  urgent
}

enum VetConsultationStatus {
  open
  in_progress
  resolved
  cancelled
}

model VetConsultation {
  id               String                 @id @default(cuid())
  farmId           String
  farm             Farm                   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animalId         String?
  animal           Animal?                @relation(fields: [animalId], references: [id], onDelete: SetNull)
  subject          String
  summary          String?
  status           VetConsultationStatus  @default(open)
  openedByUserId   String
  openedBy         User                   @relation("VetConsultOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)
  primaryVetUserId String?
  primaryVet       User?                  @relation("VetConsultPrimaryVet", fields: [primaryVetUserId], references: [id], onDelete: SetNull)
  openedAt         DateTime               @default(now())
  closedAt         DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  attachments      VetConsultationAttachment[]

  @@index([farmId, status])
  @@index([farmId, openedAt])
}

model VetConsultationAttachment {
  id               String            @id @default(cuid())
  consultationId   String
  consultation     VetConsultation   @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  url              String
  mimeType         String?
  label            String?
  uploadedByUserId String
  uploadedBy       User              @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  createdAt        DateTime          @default(now())

  @@index([consultationId])
}

enum AnimalSex {
  male
  female
  unknown
}

enum AnimalProductionCategory {
  breeding_female
  breeding_male
  fattening
  starter
  unknown
}

enum AnimalOrigin {
  farm_born
  purchased
}

enum AnimalHealthStatus {
  healthy
  sick
  recovering
}

/// Version et texte des conditions générales d''utilisation (ligne unique `current`).
model CguSettings {
  id             String   @id @default("current")
  currentVersion String
  content        String   @db.Text
  contentUrl     String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model Species {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  breeds    Breed[]
  animals   Animal[]
  livestockBatches LivestockBatch[]
}

model Breed {
  id        String   @id @default(cuid())
  speciesId String
  species   Species  @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  code      String?
  name      String
  animals   Animal[]
  livestockBatches LivestockBatch[]

  @@unique([speciesId, name])
  @@index([speciesId])
}

model Animal {
  id        String    @id @default(cuid())
  farmId    String
  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  speciesId String
  species   Species   @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  breedId   String?
  breed     Breed?    @relation(fields: [breedId], references: [id], onDelete: SetNull)
  publicId  String    @unique @default(cuid())
  tagCode   String?
  sex       AnimalSex @default(unknown)
  productionCategory AnimalProductionCategory @default(unknown)
  birthDate DateTime?
  /// Mise bas prévue (truies / suivi reproduction) — alimente le dashboard gestations.
  expectedFarrowingAt DateTime?
  status    String    @default("active")
  healthStatus AnimalHealthStatus @default(healthy)
  photoUrl  String?
  origin    AnimalOrigin?
  supplier  String?
  entryWeightKg Decimal? @db.Decimal(10, 3)
  statusChangedAt DateTime?
  soldAt          DateTime?
  soldWeightKg    Decimal? @db.Decimal(10, 3)
  soldPrice       Decimal? @db.Decimal(14, 2)
  soldCurrency    String?
  buyerName       String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  weights      AnimalWeight[]
  marketplaceListings MarketplaceListing[]
  vetConsultations VetConsultation[]
  penPlacements    PenPlacement[]
  livestockExits   LivestockExit[]
  farmTasks        FarmTask[]
  gestationsAsSow  Gestation[] @relation("GestationSow")
  gestationsAsBoar Gestation[] @relation("GestationBoar")
  /// Filiation (naissance à la ferme) — truie et verrat reproducteurs de la même exploitation.
  damId            String?
  dam              Animal?   @relation("AnimalDam", fields: [damId], references: [id], onDelete: SetNull)
  sireId           String?
  sire             Animal?   @relation("AnimalSire", fields: [sireId], references: [id], onDelete: SetNull)
  offspringAsDam   Animal[]  @relation("AnimalDam")
  offspringAsSire  Animal[]  @relation("AnimalSire")

  @@index([farmId])
  @@index([damId])
  @@index([sireId])
  @@index([farmId, status])
  @@index([farmId, healthStatus])
  @@index([farmId, expectedFarrowingAt])
  @@index([speciesId])
  @@index([publicId])
}

enum LivestockExitKind {
  sale
  mortality
  slaughter
  transfer
}

/// Sortie de cheptel structuree (vente, mortalite, abattage, transfert).
model LivestockExit {
  id                 String             @id @default(cuid())
  farmId             String
  farm               Farm               @relation("ExitOriginFarm", fields: [farmId], references: [id], onDelete: Cascade)
  animalId           String?
  animal             Animal?            @relation(fields: [animalId], references: [id], onDelete: Restrict)
  batchId            String?
  batch              LivestockBatch?    @relation(fields: [batchId], references: [id], onDelete: Restrict)
  kind               LivestockExitKind
  occurredAt         DateTime           @default(now())
  recordedByUserId   String
  recorder           User               @relation(fields: [recordedByUserId], references: [id], onDelete: Restrict)
  headcountAffected  Int?
  buyerName          String?
  price              Decimal?           @db.Decimal(14, 2)
  currency           String?
  weightKg           Decimal?           @db.Decimal(10, 3)
  invoiceRef         String?
  deathCause         String?
  symptoms           String?
  carcassYieldNote   String?
  slaughterDestination String?
  transferDestination  String?
  toFarmId           String?
  toFarm             Farm?              @relation("ExitTransferDestinationFarm", fields: [toFarmId], references: [id], onDelete: SetNull)
  note               String?
  createdAt          DateTime           @default(now())

  mortalityHealthDetail HealthMortalityDetail?

  @@index([farmId, occurredAt])
  @@index([farmId, kind])
  @@index([animalId])
  @@index([batchId])
}

/// Bande / lot homogene (mode batch ou hybride). Voir docs/LIVESTOCK_MODES_AND_HOUSING.md.
model LivestockBatch {
  id             String    @id @default(cuid())
  farmId         String
  farm           Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  speciesId      String
  species        Species   @relation(fields: [speciesId], references: [id], onDelete: Restrict)
