  recorder         User           @relation(fields: [recordedByUserId], references: [id], onDelete: Restrict)

  @@index([batchId, recordedAt])
}

/// Dossier santé unifié (vaccination, maladie, visite véto, traitement, mortalité).
enum FarmHealthRecordKind {
  vaccination
  disease
  vet_visit
  treatment
  mortality
}

enum FarmHealthEntityType {
  animal
  group
}

enum FarmDiseaseCaseStatus {
  active
  recovered
  dead
  slaughtered
}

enum FarmDiseaseSeverity {
  mild
  moderate
  severe
}

enum FarmMortalityCause {
  disease
  accident
  unknown
  other
}

model FarmHealthRecord {
  id               String               @id @default(cuid())
  farmId           String
  farm             Farm                 @relation(fields: [farmId], references: [id], onDelete: Cascade)
