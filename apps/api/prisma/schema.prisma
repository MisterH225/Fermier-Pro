model Species {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  breeds    Breed[]
  animals   Animal[]
  livestockBatches LivestockBatch[]
}

model Breed {
  id        String   @id @default(cuid())
  speciesId String
  species   Species  @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  code      String?
  name      String
  animals   Animal[]
  livestockBatches LivestockBatch[]

  @@unique([speciesId, name])
  @@index([speciesId])
}

model Animal {
  id        String    @id @default(cuid())
  farmId    String
  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  speciesId String
  species   Species   @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  breedId   String?
  breed     Breed?    @relation(fields: [breedId], references: [id], onDelete: SetNull)
  publicId  String    @unique @default(cuid())
  tagCode   String?
  sex       AnimalSex @default(unknown)
  productionCategory AnimalProductionCategory @default(unknown)
  birthDate DateTime?
  /// Âge estimé en semaines au moment de l'entrée dans la ferme (si naissance inconnue).
  ageWeeksAtEntry Int?
  /// Date d'entrée dans la ferme (≠ date d'assignation à une loge).
  entryDate       DateTime? @db.Date
  /// Mise bas prévue (truies / suivi reproduction) — alimente le dashboard gestations.
  expectedFarrowingAt DateTime?
  status    String    @default("active")
  healthStatus AnimalHealthStatus @default(healthy)
  photoUrl  String?
  origin    AnimalOrigin?
  supplier  String?
  entryWeightKg Decimal? @db.Decimal(10, 3)
  statusChangedAt DateTime?
  soldAt          DateTime?
  soldWeightKg    Decimal? @db.Decimal(10, 3)
  soldPrice       Decimal? @db.Decimal(14, 2)
  soldCurrency    String?
  buyerName       String?
  notes     String?
  /// Bande de croissance associée (portée confirmée ou bande préexistante).
  livestockBatchId String?
  livestockBatch   LivestockBatch? @relation("BatchMembers", fields: [livestockBatchId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  weights      AnimalWeight[]
  marketplaceListings MarketplaceListing[]
  vetConsultations VetConsultation[]
  penPlacements    PenPlacement[]
  livestockExits   LivestockExit[]
  farmTasks        FarmTask[]
  gestationsAsSow  Gestation[] @relation("GestationSow")
  gestationsAsBoar Gestation[] @relation("GestationBoar")
  /// Filiation (naissance à la ferme) — truie et verrat reproducteurs de la même exploitation.
  damId            String?
  dam              Animal?   @relation("AnimalDam", fields: [damId], references: [id], onDelete: SetNull)
  sireId           String?
  sire             Animal?   @relation("AnimalSire", fields: [sireId], references: [id], onDelete: SetNull)
  offspringAsDam   Animal[]  @relation("AnimalDam")
  offspringAsSire  Animal[]  @relation("AnimalSire")

  @@index([farmId])
  @@index([livestockBatchId])
  @@index([damId])
  @@index([sireId])
  @@index([farmId, status])
  @@index([farmId, healthStatus])
  @@index([farmId, expectedFarrowingAt])
  @@index([speciesId])
  @@index([publicId])
}

enum LivestockExitKind {
  sale
  mortality
  slaughter
  transfer
