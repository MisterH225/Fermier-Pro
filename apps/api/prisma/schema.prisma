  AWAITING_PAYMENT
  APPOINTMENT_CONFIRMED
  APPOINTMENT_IN_PROGRESS
  APPOINTMENT_COMPLETED
  APPOINTMENT_RATED
  APPOINTMENT_REFUSED
  PAYMENT_EXPIRED
  CANCELLED_BY_PRODUCER
  CANCELLED_BY_VET
}

enum VetAppointmentConflictStatus {
  AVAILABLE
  CONFLICT_NEARBY
  CONFLICT_EXACT
}

enum VetAppointmentFundMovementKind {
  HOLD
  RELEASE_TO_VET
  REFUND_PRODUCER
  COMMISSION
}

/// Rendez-vous vétérinaire producteur ↔ véto (demande → acceptation → escrow → prestation → avis).
model VetAppointment {
  id                     String                      @id @default(cuid())
  farmId                 String
  farm                   Farm                        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  producerUserId         String
  producer               User                        @relation("AppointmentProducer", fields: [producerUserId], references: [id], onDelete: Restrict)
  vetProfileId           String
  vetProfile             VetProfile                  @relation(fields: [vetProfileId], references: [id], onDelete: Restrict)
  vetUserId              String
  vet                    User                        @relation("AppointmentVet", fields: [vetUserId], references: [id], onDelete: Restrict)
  status                 VetAppointmentStatus        @default(APPOINTMENT_REQUESTED)
  requestedAt            DateTime
  confirmedAt            DateTime?
  estimatedDurationHours Decimal                     @default(1) @db.Decimal(4, 2)
  reason                 String
  notes                  String?
  farmLocation           String
  refusalReason          String?
  vetResponseNotes       String?
  servicePrice           Decimal?                    @db.Decimal(14, 2)
  commissionRate         Decimal                     @default(0.05) @db.Decimal(5, 4)
  commissionAmount       Decimal?                    @db.Decimal(14, 2)
  vetReceivedAmount      Decimal?                    @db.Decimal(14, 2)
  blockedAmount          Decimal?                    @db.Decimal(14, 2)
  paymentDeadline        DateTime?
  paymentConfirmedAt     DateTime?
  paymentProviderRef     String?
  paymentMethod          MarketplacePaymentMethod?
  completedAt            DateTime?
  cancelledAt            DateTime?
  cancellationReason     String?
  conflictStatus         VetAppointmentConflictStatus?
  conflictDetails        Json?
  calendarBlocked        Boolean                     @default(false)
  currency               String                      @default("XOF")
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  rating                 VetAppointmentRating?
  fundMovements          VetAppointmentFundMovement[]
  platformRevenue        PlatformRevenue?
  walletEntries          UserWalletEntry[]

  @@index([vetUserId, status])
  @@index([producerUserId, status])
  @@index([farmId, status])
  @@index([status, paymentDeadline])
  @@index([status, confirmedAt])
}

model VetAppointmentRating {
  id             String         @id @default(cuid())
  appointmentId  String         @unique
  appointment    VetAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  vetProfileId   String
  vetProfile     VetProfile     @relation(fields: [vetProfileId], references: [id], onDelete: Cascade)
  producerUserId String
  rating         Int
  comment        String?
  tags           String[]       @default([])
  createdAt      DateTime       @default(now())

  @@index([vetProfileId])
}

model VetAppointmentFundMovement {
  id            String                         @id @default(cuid())
  appointmentId String
  appointment   VetAppointment                 @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  kind          VetAppointmentFundMovementKind
  amount        Decimal                        @db.Decimal(14, 2)
  currency      String                         @default("XOF")
  providerRef   String?
  note          String?
  createdAt     DateTime                       @default(now())

  @@index([appointmentId])
}

enum AnimalSex {
  male
