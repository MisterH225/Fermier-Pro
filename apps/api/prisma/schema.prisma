  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  litter            Litter?
  vaccines          GestationVaccine[]
  checklistItems    GestationChecklistItem[]

  @@index([farmId, status])
  @@index([farmId, expectedBirthDate])
  @@index([sowId])
}

model Litter {
  id                   String                 @id @default(cuid())
  gestationId          String                 @unique
  gestation            Gestation              @relation(fields: [gestationId], references: [id], onDelete: Cascade)
  farmId               String
  bornAlive            Int
  stillborn            Int                    @default(0)
  mummified            Int                    @default(0)
  averageBirthWeightKg Decimal?               @db.Decimal(10, 3)
  deliveryType         GestationDeliveryType  @default(normal)
  vetAssistance        Boolean                @default(false)
  weaningDate          DateTime?
  starterBatchId       String?
  notes                String?
  recordedAt           DateTime               @default(now())
  createdAt            DateTime               @default(now())

  @@index([farmId])
}

model GestationVaccine {
  id                    String                 @id @default(cuid())
  gestationId           String
  gestation             Gestation              @relation(fields: [gestationId], references: [id], onDelete: Cascade)
  vaccineName           String
  scheduledDate         DateTime
  administeredDate      DateTime?
  status                GestationVaccineStatus @default(pending)
  linkedHealthRecordId  String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([gestationId])
  @@index([gestationId, status])
}

model GestationChecklistItem {
  id          String    @id @default(cuid())
  gestationId String
  gestation   Gestation @relation(fields: [gestationId], references: [id], onDelete: Cascade)
  itemLabel   String
  isChecked   Boolean   @default(false)
  checkedAt   DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([gestationId])
}

model GestationSettings {
  id                    String   @id @default(cuid())
  farmId                String   @unique
  farm                  Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  gestationDurationDays Int      @default(114)
  weaningDurationDays   Int      @default(28)
  vaccineSchedule       Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

enum AccountStatus {
  active
  suspended
  banned
}

enum ProfileModerationStatus {
  active
  suspended
  banned
}

enum AdminAuditTargetType {
  account
  vet_profile
  farm_profile
  buyer_profile
  technician_profile
}

enum AdminAuditAction {
  suspend
  unsuspend
  ban
  unban
  delete_profile
  delete_account
  warn
  message
}

enum AdminMessageType {
  notification
  warning
  info
}

/// Journal des actions SuperAdmin (modération utilisateurs).
model AdminAuditLog {
  id                String               @id @default(cuid())
  adminUserId       String
  admin             User                 @relation("AdminAuditActor", fields: [adminUserId], references: [id], onDelete: Restrict)
  targetUserId      String
  target            User                 @relation("AdminAuditTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  targetProfileType AdminAuditTargetType
  targetProfileId   String?
  action            AdminAuditAction
  reason            String?
  metadata          Json?
  createdAt         DateTime             @default(now())

  @@index([targetUserId, createdAt])
  @@index([adminUserId, createdAt])
  @@index([createdAt])
  @@index([action])
}

/// Messages admin → utilisateur (in-app + push).
model AdminMessage {
  id              String           @id @default(cuid())
  adminUserId     String
  admin           User             @relation("AdminMessageSender", fields: [adminUserId], references: [id], onDelete: Restrict)
  recipientUserId String
  recipient       User             @relation("AdminMessageRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  subject         String
  message         String
  type            AdminMessageType @default(notification)
  isRead          Boolean          @default(false)
  sentAt          DateTime         @default(now())
  readAt          DateTime?

  @@index([recipientUserId, sentAt])
  @@index([recipientUserId, isRead])
}

/// Comptes autorisés sur la console SuperAdmin (web).
model SuperAdmin {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy String?
  createdAt DateTime @default(now())

  @@index([userId])
}

enum SanitaryAlertType {
  auto
  manual
}

enum SanitaryAlertLevel {
  info
  warning
  critical
}

/// Alertes sanitaires territoriales (carte + notifications).
model SanitaryAlert {
  id          String              @id @default(cuid())
  zoneName    String
  countryCode String?
  regionCode  String?
  alertType   SanitaryAlertType
  level       SanitaryAlertLevel  @default(warning)
  diseaseName String?
  caseCount   Int?
  message     String
  createdBy   String?
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?

  @@index([isActive, createdAt])
  @@index([countryCode])
}

/// Paramètres globaux plateforme (périmètre carte, seuils alertes).
model PlatformSettings {
  id                    String   @id @default("default")
  mapGeographicScope    String   @default("west_africa")
  mapCountryCodes       Json?
  alertCaseThreshold    Int      @default(5)
  alertPeriodDays       Int      @default(30)
  alertDefaultLevel     SanitaryAlertLevel @default(warning)
  adminNotifyEmail      String?
  reportFrequencyDays   Int      @default(7)
  updatedAt             DateTime @updatedAt
}

/// Catégories de l'indice PigPrice (marché porcin agrégé).
enum PigPriceIndexCategory {
  porcelet
  croissance
  charcutier
  reproducteur
  global
}

/// Indice journalier agrégé et anonymisé (transactions + signal annonces).
model PigPriceIndexDaily {
  id               String                @id @default(cuid())
  date             DateTime              @db.Date
  category         PigPriceIndexCategory
  avgPricePerKg    Decimal               @db.Decimal(14, 4)
  weightedAvgPrice Decimal               @db.Decimal(14, 4)
  minPrice         Decimal?              @db.Decimal(14, 4)
  maxPrice         Decimal?              @db.Decimal(14, 4)
  transactionCount Int                   @default(0)
  listingAvgPrice  Decimal?              @db.Decimal(14, 4)
  listingCount     Int                   @default(0)
  variationPct     Decimal?              @db.Decimal(8, 4)
  calculatedAt     DateTime              @default(now())

  @@unique([date, category])
  @@index([date(sort: Desc)])
}
