generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProfileType {
  producer
  technician
  veterinarian
  buyer
}

enum SmartAlertModule {
  stock
  health
  finance
  gestation
  cheptel
}

enum SmartAlertPriority {
  critical
  warning
  info
}

/// Mode de suivi principal a la ferme (reversible ; voir docs/LIVESTOCK_MODES_AND_HOUSING.md).
enum FarmLivestockMode {
  individual
  batch
  hybrid
}

enum MembershipRole {
  owner
  manager
  worker
  veterinarian
  viewer
}

model User {
  id                    String               @id @default(cuid())
  supabaseUserId        String               @unique
  email                 String?              @unique
  fullName              String?
  /// Prénom affiché (accueil, OAuth Google souvent pré-rempli à la création).
  firstName             String?
  /// Nom de famille (OAuth ou saisi).
  lastName              String?
  /// URL publique avatar (ex. Supabase Storage).
  avatarUrl             String?
  /// Libellé ferme sur l’accueil producteur (prioritaire sur la 1re ferme).
  producerHomeFarmName  String?
  homeLatitude          Decimal?             @db.Decimal(10, 7)
  homeLongitude         Decimal?             @db.Decimal(10, 7)
  homeLocationLabel     String?
  /// `gps` | `manual` — origine des coordonnées / libellé lieu.
  homeLocationSource    String?
  phone                 String?              @unique
  isActive              Boolean              @default(true)
  /// Préférences notifications push (opt-in ; jetons dans `PushDevice`).
  notificationsEnabled Boolean             @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  profiles              Profile[]
  pushDevices           PushDevice[]
  memberships           FarmMembership[]
  ownedFarms            Farm[]               @relation("FarmOwner")
  farmInvitesCreated    FarmInvitation[]     @relation("InvitationCreator")
  farmInvitesScanned    FarmInvitation[]     @relation("InvitationScanner")
  tasksAssigned         FarmTask[]           @relation("TaskAssignee")
  tasksCreated          FarmTask[]           @relation("TaskCreator")
  expensesCreated       FarmExpense[]
  revenuesCreated       FarmRevenue[]
  healthEventsRecorded       AnimalHealthEvent[]
  batchHealthEventsRecorded LivestockBatchHealthEvent[]
  listingsAsSeller      MarketplaceListing[] @relation("ListingSeller")
  offersAsBuyer         MarketplaceOffer[]   @relation("OfferBuyer")
  vetConsultsOpened     VetConsultation[]    @relation("VetConsultOpenedBy")
  vetConsultsPrimary    VetConsultation[]    @relation("VetConsultPrimaryVet")
  vetConsultAttachments VetConsultationAttachment[]
  penPlacementsCreated PenPlacement[] @relation("PenPlacementCreator")
  penLogsRecorded      PenLog[]       @relation("PenLogRecorder")
  livestockExitsRecorded LivestockExit[]
  feedStockMovementsCreated FeedStockMovement[]
  livestockStatusLogsRecorded LivestockStatusLog[] @relation("LivestockStatusLogRecorder")
  farmHealthRecordsRecorded FarmHealthRecord[] @relation("FarmHealthRecordRecorder")
  farmMarketRatingsGiven FarmMarketRating[] @relation("FarmMarketRatingAuthor")
  chatRoomMemberships ChatRoomMember[]
  chatMessagesSent    ChatMessage[]
  auditLogs           AuditLog[]

  @@index([email])
  @@index([phone])
}

/// Jeton Expo push (ou autre) enregistré pour l’utilisateur — un enregistrement par appareil / jeton.
model PushDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Profile {
  id          String      @id @default(cuid())
  userId      String
  type        ProfileType
  displayName String?
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model Farm {
  id           String             @id @default(cuid())
  ownerId      String
  name         String
  speciesFocus String             @default("porcin")
  /// Suivi individuel, par bandes uniquement, ou hybride (politiques par categorie).
  livestockMode              FarmLivestockMode @default(individual)
  /// Ex. { "sow": "individual", "finisher": "batch" } — cles metier a stabiliser avec le referentiel categories.
  livestockCategoryPolicies Json?
  /// Parametrage batiments / loges (synthese editable ; detail dans Barn/Pen).
  housingBuildingsCount Int?
  housingPensPerBuilding Int?
  housingMaxPigsPerPen   Int?
  latitude     Decimal?
  longitude    Decimal?
  address      String?
  capacity     Int?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  owner        User               @relation("FarmOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships  FarmMembership[]
  invitations  FarmInvitation[]
  activityLogs MemberActivityLog[]
  animals      Animal[]
  livestockStatusLogs LivestockStatusLog[]
  tasks        FarmTask[]
  expenses     FarmExpense[]
  revenues     FarmRevenue[]
  marketplaceListings MarketplaceListing[]
  vetConsultations    VetConsultation[]
  livestockBatches  LivestockBatch[]
  barns             Barn[]
  livestockExits    LivestockExit[] @relation("ExitOriginFarm")
  transfersReceived LivestockExit[] @relation("ExitTransferDestinationFarm")
  chatRoom          ChatRoom?
  auditLogs         AuditLog[]
  feedTypes             FeedType[]
  feedStockMovements  FeedStockMovement[]
  financeSettings   FarmFinanceSettings?
  financeCategories FinanceCategory[]
  farmHealthRecords FarmHealthRecord[]
  marketRatingsReceived FarmMarketRating[]
  smartAlerts          SmartAlert[]
  farmAlertSettings    FarmAlertSettings?
  farmReports          FarmReport[]
}

enum FinanceCategoryType {
  income
  expense
}

/// Paramètres financiers globaux de la ferme (devise, alertes).
model FarmFinanceSettings {
  id                  String   @id @default(cuid())
  farmId              String   @unique
  farm                Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  currencyCode        String   @default("XOF")
  currencySymbol      String   @default("FCFA")
  lowBalanceThreshold Decimal? @db.Decimal(14, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Catégorie de dépense ou de revenu (référentiel par ferme).
model FinanceCategory {
  id        String              @id @default(cuid())
  farmId    String
  farm      Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  type      FinanceCategoryType
  key       String
  name      String
  icon      String?
  isDefault Boolean             @default(false)
  createdAt DateTime            @default(now())
  expenses  FarmExpense[]
  revenues  FarmRevenue[]

  @@unique([farmId, type, key])
  @@index([farmId, type])
}

/// Journal des changements de statut animal / bande (cheptel).
model LivestockStatusLog {
  id               String   @id @default(cuid())
  farmId           String
  farm             Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  /// `animal` | `batch`
  entityType       String
  entityId         String
  oldStatus        String?
  newStatus        String
  note             String?
  createdAt        DateTime @default(now())
  recordedByUserId String
  recorder         User     @relation("LivestockStatusLogRecorder", fields: [recordedByUserId], references: [id], onDelete: Restrict)

  @@index([farmId, createdAt])
  @@index([entityType, entityId])
}

/// Journal d'audit applicatif (actions sensibles). Voir docs/SECURITY_ARCHITECTURE.md.
model AuditLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  actorUserId  String
  actor        User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  farmId       String?
  farm         Farm?    @relation(fields: [farmId], references: [id], onDelete: SetNull)
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?

  @@index([actorUserId, createdAt])
  @@index([farmId, createdAt])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

enum TaskStatus {
  todo
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  normal
  high
}

model FarmTask {
  id              String       @id @default(cuid())
  farmId          String
  farm            Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  category        String?
  status          TaskStatus   @default(todo)
  priority        TaskPriority @default(normal)
  dueAt           DateTime?
  completedAt     DateTime?
  assignedUserId  String?
  assignee        User?        @relation("TaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdByUserId String
  creator         User         @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([farmId, status])
  @@index([assignedUserId])
}

model FarmExpense {
  id                 String            @id @default(cuid())
  farmId             String
  farm               Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  amount             Decimal           @db.Decimal(14, 2)
  currency           String            @default("XOF")
  label              String
  /// Ancien libellé libre ; préférer `financeCategoryId`.
  category           String?
  note               String?
  occurredAt         DateTime          @default(now())
  createdByUserId    String
  creator            User              @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt          DateTime          @default(now())
  financeCategoryId  String?
  financeCategory    FinanceCategory?  @relation(fields: [financeCategoryId], references: [id], onDelete: SetNull)
  linkedEntityType   String?
  linkedEntityId     String?
  attachmentUrl      String?
  healthVetVisitLink HealthVetVisitDetail?
  healthTreatmentLink HealthTreatmentDetail?

  @@index([farmId, occurredAt])
  @@index([financeCategoryId])
}

model FarmRevenue {
  id                 String            @id @default(cuid())
  farmId             String
  farm               Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  amount             Decimal           @db.Decimal(14, 2)
  currency           String            @default("XOF")
  label              String
  category           String?
  note               String?
  occurredAt         DateTime          @default(now())
  createdByUserId    String
  creator            User              @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt          DateTime          @default(now())
  financeCategoryId  String?
  financeCategory    FinanceCategory?  @relation(fields: [financeCategoryId], references: [id], onDelete: SetNull)
  linkedEntityType   String?
  linkedEntityId     String?
  attachmentUrl      String?

  @@index([farmId, occurredAt])
  @@index([financeCategoryId])
}

enum HealthSeverity {
  info
  watch
  urgent
}

enum VetConsultationStatus {
  open
  in_progress
  resolved
  cancelled
}

model AnimalHealthEvent {
  id               String         @id @default(cuid())
  animalId         String
  animal           Animal         @relation(fields: [animalId], references: [id], onDelete: Cascade)
  severity         HealthSeverity @default(info)
  title            String
  body             String?
  recordedAt       DateTime       @default(now())
  recordedByUserId String
  recorder         User           @relation(fields: [recordedByUserId], references: [id], onDelete: Restrict)

  @@index([animalId, recordedAt])
}

model VetConsultation {
  id               String                 @id @default(cuid())
  farmId           String
  farm             Farm                   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animalId         String?
  animal           Animal?                @relation(fields: [animalId], references: [id], onDelete: SetNull)
  subject          String
  summary          String?
  status           VetConsultationStatus  @default(open)
  openedByUserId   String
  openedBy         User                   @relation("VetConsultOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)
  primaryVetUserId String?
  primaryVet       User?                  @relation("VetConsultPrimaryVet", fields: [primaryVetUserId], references: [id], onDelete: SetNull)
  openedAt         DateTime               @default(now())
  closedAt         DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  attachments      VetConsultationAttachment[]

  @@index([farmId, status])
  @@index([farmId, openedAt])
}

model VetConsultationAttachment {
  id               String            @id @default(cuid())
  consultationId   String
  consultation     VetConsultation   @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  url              String
  mimeType         String?
  label            String?
  uploadedByUserId String
  uploadedBy       User              @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  createdAt        DateTime          @default(now())

  @@index([consultationId])
}

enum AnimalSex {
  male
  female
  unknown
}

model Species {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  breeds    Breed[]
  animals   Animal[]
  livestockBatches LivestockBatch[]
}

model Breed {
  id        String   @id @default(cuid())
  speciesId String
  species   Species  @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  code      String?
  name      String
  animals   Animal[]
  livestockBatches LivestockBatch[]

  @@unique([speciesId, name])
  @@index([speciesId])
}

model Animal {
  id        String    @id @default(cuid())
  farmId    String
  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  speciesId String
  species   Species   @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  breedId   String?
  breed     Breed?    @relation(fields: [breedId], references: [id], onDelete: SetNull)
  publicId  String    @unique @default(cuid())
  tagCode   String?
  sex       AnimalSex @default(unknown)
  birthDate DateTime?
  /// Mise bas prévue (truies / suivi reproduction) — alimente le dashboard gestations.
  expectedFarrowingAt DateTime?
  status    String    @default("active")
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  weights      AnimalWeight[]
  healthEvents AnimalHealthEvent[]
  marketplaceListings MarketplaceListing[]
  vetConsultations VetConsultation[]
  penPlacements    PenPlacement[]
  livestockExits   LivestockExit[]

  @@index([farmId])
  @@index([farmId, status])
  @@index([farmId, expectedFarrowingAt])
  @@index([speciesId])
  @@index([publicId])
}

enum LivestockExitKind {
  sale
  mortality
  slaughter
  transfer
}

/// Sortie de cheptel structuree (vente, mortalite, abattage, transfert).
model LivestockExit {
  id                 String             @id @default(cuid())
  farmId             String
  farm               Farm               @relation("ExitOriginFarm", fields: [farmId], references: [id], onDelete: Cascade)
  animalId           String?
  animal             Animal?            @relation(fields: [animalId], references: [id], onDelete: Restrict)
  batchId            String?
  batch              LivestockBatch?    @relation(fields: [batchId], references: [id], onDelete: Restrict)
  kind               LivestockExitKind
  occurredAt         DateTime           @default(now())
  recordedByUserId   String
  recorder           User               @relation(fields: [recordedByUserId], references: [id], onDelete: Restrict)
  headcountAffected  Int?
  buyerName          String?
  price              Decimal?           @db.Decimal(14, 2)
  currency           String?
  weightKg           Decimal?           @db.Decimal(10, 3)
  invoiceRef         String?
  deathCause         String?
  symptoms           String?
  carcassYieldNote   String?
  slaughterDestination String?
  transferDestination  String?
  toFarmId           String?
  toFarm             Farm?              @relation("ExitTransferDestinationFarm", fields: [toFarmId], references: [id], onDelete: SetNull)
  note               String?
  createdAt          DateTime           @default(now())

  mortalityHealthDetail HealthMortalityDetail?

  @@index([farmId, occurredAt])
  @@index([farmId, kind])
  @@index([animalId])
  @@index([batchId])
}

/// Bande / lot homogene (mode batch ou hybride). Voir docs/LIVESTOCK_MODES_AND_HOUSING.md.
model LivestockBatch {
  id             String    @id @default(cuid())
  farmId         String
  farm           Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  speciesId      String
  species        Species   @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  breedId        String?
  breed          Breed?    @relation(fields: [breedId], references: [id], onDelete: SetNull)
  publicId       String    @unique @default(cuid())
  name           String
  /// Cle metier hybride (ex. nursery, finisher) — referentiel a stabiliser.
  categoryKey    String?
  headcount      Int       @default(0)
  avgBirthDate   DateTime?
  sourceTag      String?
  status         String    @default("active")
  notes          String?
  expectedExitAt DateTime?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  weights        LivestockBatchWeight[]
  healthEvents   LivestockBatchHealthEvent[]
  penPlacements  PenPlacement[]
  livestockExits LivestockExit[]

  @@index([farmId])
  @@index([farmId, status])
  @@index([publicId])
}

model Barn {
  id        String   @id @default(cuid())
  farmId    String
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name      String
  code      String?
  notes     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pens      Pen[]

  @@index([farmId])
}

model Pen {
  id         String   @id @default(cuid())
  barnId     String
  barn       Barn     @relation(fields: [barnId], references: [id], onDelete: Cascade)
  name       String
  code       String?
  zoneLabel  String?
  capacity   Int?
  status     String   @default("active")
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  placements PenPlacement[]
  logs       PenLog[]

  @@index([barnId])
}

model PenPlacement {
  id               String          @id @default(cuid())
  penId            String
  pen              Pen             @relation(fields: [penId], references: [id], onDelete: Cascade)
  animalId         String?
  animal           Animal?         @relation(fields: [animalId], references: [id], onDelete: Cascade)
  batchId          String?
  batch            LivestockBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  startedAt        DateTime        @default(now())
  endedAt          DateTime?
  note             String?
  createdByUserId  String
  creator          User            @relation("PenPlacementCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([penId, endedAt])
  @@index([animalId, endedAt])
  @@index([batchId, endedAt])
}

enum PenLogType {
  cleaning
  disinfection
  mortality
  treatment
  other
}

model PenLog {
  id               String     @id @default(cuid())
  penId            String
  pen              Pen        @relation(fields: [penId], references: [id], onDelete: Cascade)
  type             PenLogType @default(other)
  title            String
  body             String?
  recordedAt       DateTime   @default(now())
  recordedByUserId String
  recorder         User       @relation("PenLogRecorder", fields: [recordedByUserId], references: [id], onDelete: Restrict)

  @@index([penId, recordedAt])
}

model LivestockBatchWeight {
  id                String         @id @default(cuid())
  batchId           String
  batch             LivestockBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  /// Poids moyen estime par tete (kg).
  avgWeightKg       Decimal        @db.Decimal(10, 3)
  headcountSnapshot Int?
  measuredAt        DateTime       @default(now())
  note              String?
  createdAt         DateTime       @default(now())

  @@index([batchId, measuredAt])
}

model LivestockBatchHealthEvent {
  id               String         @id @default(cuid())
  batchId          String
  batch            LivestockBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  severity         HealthSeverity @default(info)
  title            String
  body             String?
  recordedAt       DateTime       @default(now())
  recordedByUserId String
  recorder         User           @relation(fields: [recordedByUserId], references: [id], onDelete: Restrict)

  @@index([batchId, recordedAt])
}

/// Dossier santé unifié (vaccination, maladie, visite véto, traitement, mortalité).
enum FarmHealthRecordKind {
  vaccination
  disease
  vet_visit
  treatment
  mortality
}

enum FarmHealthEntityType {
  animal
  group
}

enum FarmDiseaseCaseStatus {
  active
  recovered
  dead
  slaughtered
}

enum FarmMortalityCause {
  disease
  accident
  unknown
  other
}

model FarmHealthRecord {
  id               String               @id @default(cuid())
  farmId           String
  farm             Farm                 @relation(fields: [farmId], references: [id], onDelete: Cascade)
  kind             FarmHealthRecordKind
  entityType       FarmHealthEntityType
  entityId         String
  occurredAt       DateTime             @default(now())
  status           String               @default("completed")
  notes            String?
  attachmentUrl    String?
  recordedByUserId String
  recorder         User                 @relation("FarmHealthRecordRecorder", fields: [recordedByUserId], references: [id], onDelete: Restrict)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  vaccination HealthVaccinationDetail?
  disease     HealthDiseaseDetail?
  vetVisit    HealthVetVisitDetail?
  treatment   HealthTreatmentDetail?
  mortality   HealthMortalityDetail?

  @@index([farmId, kind, occurredAt])
  @@index([farmId, entityType, entityId])
}

model HealthVaccinationDetail {
  healthRecordId String           @id
  healthRecord   FarmHealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  vaccineName    String
  vaccineType    String?
  dose           Decimal?         @db.Decimal(12, 4)
  doseUnit       String?
  practitioner   String?
  nextReminderAt DateTime?
  reminderDays   Int?
}

model HealthDiseaseDetail {
  healthRecordId          String                @id
  healthRecord            FarmHealthRecord      @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  symptoms                Json?
  diagnosis               String?
  caseStatus              FarmDiseaseCaseStatus @default(active)
  linkedTreatmentRecordId String?
}

model HealthVetVisitDetail {
  healthRecordId     String          @id
  healthRecord       FarmHealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  vetName            String
  vetContact         String?
  reason             String
  report             String?
  prescriptionUrl    String?
  cost               Decimal?        @db.Decimal(14, 2)
  financeExpenseId   String?         @unique
  financeExpense     FarmExpense?    @relation(fields: [financeExpenseId], references: [id], onDelete: SetNull)
}

model HealthTreatmentDetail {
  healthRecordId     String           @id
  healthRecord       FarmHealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  drugName           String
  dosage             String?
  unit               String?
  frequency          String?
  startDate          DateTime
  endDate            DateTime?
  cost               Decimal?         @db.Decimal(14, 2)
  financeExpenseId   String?          @unique
  financeExpense     FarmExpense?     @relation(fields: [financeExpenseId], references: [id], onDelete: SetNull)
}

model HealthMortalityDetail {
  healthRecordId        String           @id
  healthRecord          FarmHealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  cause                 FarmMortalityCause
  linkedDiseaseRecordId String?
  livestockExitId       String?          @unique
  livestockExit         LivestockExit?   @relation(fields: [livestockExitId], references: [id], onDelete: SetNull)
}

enum ListingStatus {
  draft
  published
  reserved
  sold
  cancelled
  expired
}

enum OfferStatus {
  pending
  accepted
  rejected
  withdrawn
  countered
}

/// Catégorie d’annonce porc sur le Market (porcelets, reproducteurs, etc.).
enum ListingMarketCategory {
  piglet
  breeder
  butcher
  reformed
}

model MarketplaceListing {
  id            String          @id @default(cuid())
  sellerUserId  String
  seller        User            @relation("ListingSeller", fields: [sellerUserId], references: [id], onDelete: Restrict)
  farmId        String?
  farm          Farm?           @relation(fields: [farmId], references: [id], onDelete: SetNull)
  animalId      String?
  animal        Animal?         @relation(fields: [animalId], references: [id], onDelete: SetNull)
  /// Catégorie métier (affiche filtres Market). Optionnel pour annonces historiques.
  category      ListingMarketCategory?
  /// URLs photos (Supabase Storage ou autre), ordre d’affichage = ordre du tableau.
  photoUrls     Json            @default("[]")
  /// Identifiants animaux concernés (lien cheptel) ; `animalId` peut rester le principal pour compat.
  animalIds     Json            @default("[]")
  totalWeightKg Decimal?        @db.Decimal(14, 4)
  /// Prix au kg demandé par le vendeur (prioritaire sur `unitPrice` pour le flux porc).
  pricePerKg    Decimal?        @db.Decimal(14, 4)
  /// Prix total calculé ou saisi ; affichage principal grille Market.
  totalPrice    Decimal?        @db.Decimal(14, 2)
  breedLabel    String?
  title         String
  description   String?
  unitPrice     Decimal?        @db.Decimal(14, 2)
  quantity      Int?
  currency      String          @default("XOF")
  locationLabel String?
  /// Résumé sanitaire figé ou surchargé à la publication (JSON côté API).
  healthSummary Json?
  status        ListingStatus   @default(draft)
  publishedAt   DateTime?
  expiresAt     DateTime?
  viewsCount    Int             @default(0)
  consultationsCount Int      @default(0)
  /// Rendez-vous de retrait des animaux (convenu hors paiement in-app).
  pickupAt      DateTime?
  pickupNote    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  offers        MarketplaceOffer[]

  @@index([sellerUserId])
  @@index([status])
  @@index([farmId])
  @@index([category])
}

enum FeedTypeUnit {
  kg
  tonne
  sac
}

enum FeedMovementKind {
  in
  stock_check
}

/// Type d'aliment (croissance, démarrage, etc.) — paramètres et stock agrégé ferme.
model FeedType {
  id                    String        @id @default(cuid())
  farmId                String
  farm                  Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name                  String
  unit                  FeedTypeUnit  @default(kg)
  /// Seuil bas (jours de stock restant) pour alertes personnalisées (défaut 15 jours côté métier UI).
  lowStockThresholdDays Int           @default(15)
  color                 String        @default("#5d7a1f")
  /// Poids d'un sac (kg), requis pour saisie en sacs / contrôles inventaire.
  weightPerBagKg        Decimal?      @db.Decimal(12, 4)
  /// Dernier inventaire sacs restants (après dernier contrôle).
  bagCountCurrent       Decimal?      @db.Decimal(14, 4)
  lastCheckDate         DateTime?
  /// Stock courant agrégé (kg).
  currentStockKg        Decimal       @default(0) @db.Decimal(14, 4)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  movements             FeedStockMovement[]

  @@index([farmId])
}

/// Entrées et contrôles de stock (consommation dérivée des inventaires).
model FeedStockMovement {
  id                   String           @id @default(cuid())
  farmId               String
  farm                 Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  feedTypeId           String
  feedType             FeedType         @relation(fields: [feedTypeId], references: [id], onDelete: Cascade)
  kind                 FeedMovementKind
  /// Quantité ajoutée (kg) pour une entrée `in`.
  quantityKg           Decimal?         @db.Decimal(14, 4)
  bagsCounted          Decimal?         @db.Decimal(14, 4)
  bagsConsumed         Decimal?         @db.Decimal(14, 4)
  daysSinceLastCheck   Int?
  dailyConsumptionKg   Decimal?         @db.Decimal(14, 6)
  stockAfterKg         Decimal          @db.Decimal(14, 4)
  supplier             String?
  unitPrice            Decimal?         @db.Decimal(14, 2)
  notes                String?
  occurredAt           DateTime         @default(now())
  linkedExpenseId      String?
  createdByUserId      String
  creator              User             @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt            DateTime         @default(now())

  @@index([farmId, occurredAt])
  @@index([feedTypeId, occurredAt])
}

model MarketplaceOffer {
  id           String             @id @default(cuid())
  listingId    String
  listing      MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerUserId  String
  buyer        User               @relation("OfferBuyer", fields: [buyerUserId], references: [id], onDelete: Restrict)
  buyerFarmId  String?
  /// Prix / kg proposé par l’acheteur (si renseigné, `offeredPrice` = total de l’offre).
  proposedPricePerKg Decimal?   @db.Decimal(14, 4)
  offeredPrice Decimal            @db.Decimal(14, 2)
  quantity     Int?
  message      String?
  /// Contre-proposition vendeur : prix / kg.
  counterPricePerKg Decimal?     @db.Decimal(14, 4)
  status       OfferStatus        @default(pending)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([listingId])
  @@index([buyerUserId])
  @@index([listingId, status])
}

/// Avis acheteur → ferme (notation Market).
model FarmMarketRating {
  id              String   @id @default(cuid())
  farmId          String
  farm            Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  ratedByUserId String
  rater           User     @relation("FarmMarketRatingAuthor", fields: [ratedByUserId], references: [id], onDelete: Cascade)
  score           Int
  comment         String?
  createdAt       DateTime @default(now())

  @@unique([farmId, ratedByUserId])
  @@index([farmId])
}

model AnimalWeight {
  id         String   @id @default(cuid())
  animalId   String
  animal     Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  weightKg   Decimal  @db.Decimal(10, 3)
  measuredAt DateTime @default(now())
  note       String?
  createdAt  DateTime @default(now())

  @@index([animalId, measuredAt])
}

/// Type d'invitation collaborative.
/// - share_link : lien créé par l'owner avec rôle/permissions pré-encodés
///   (cas particulier : `isDefault=true` = lien par défaut généré à la
///   création de la ferme, support du QR code « accès collaboratif »).
/// - scan_request : demande générée quand un utilisateur scanne un lien
///   par défaut ; l'owner doit valider rôle + permissions.
enum FarmInvitationKind {
  share_link
  scan_request
}

enum FarmInvitationStatus {
  pending
  accepted
  rejected
  expired
}

model FarmInvitation {
  id               String                 @id @default(cuid())
  farmId           String
  farm             Farm                   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdById      String
  creator          User                   @relation("InvitationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  /// Null tant que l'owner n'a pas accepté un scan_request ou pour les liens par défaut non encore configurés.
  role             MembershipRole?
  scopes           String[]               @default([])
  token            String                 @unique
  expiresAt        DateTime
  redeemedAt       DateTime?
  redeemedByUserId String?
  inviteeEmail     String?
  inviteePhone     String?
  createdAt        DateTime               @default(now())

  kind             FarmInvitationKind     @default(share_link)
  status           FarmInvitationStatus   @default(pending)
  /// Vrai pour le lien collaboratif par défaut (créé à la création de la ferme).
  isDefault        Boolean                @default(false)
  /// Vue UI des permissions ({ readOnly, dataEntry, health, finance }) — alignée sur `scopes`.
  permissions      Json?
  /// Étiquette UI côté mobile (`veterinarian` | `technician` | `partner`).
  recipientKind    String?
  acceptedAt       DateTime?
  rejectedAt       DateTime?
  /// Utilisateur ayant scanné le QR par défaut (uniquement sur kind=scan_request).
  scannedByUserId  String?
  scannedBy        User?                  @relation("InvitationScanner", fields: [scannedByUserId], references: [id], onDelete: SetNull)

  @@index([farmId])
  @@index([expiresAt])
  @@index([farmId, kind, status])
  @@index([farmId, isDefault])
}

model FarmMembership {
  id          String         @id @default(cuid())
  farmId      String
  userId      String
  role        MembershipRole
  scopes      String[]
  /// Vue UI des permissions ({ readOnly, dataEntry, health, finance }) — alignée sur `scopes`.
  permissions Json?
  invitedAt   DateTime?
  acceptedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  farm        Farm           @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityLogs MemberActivityLog[]

  @@unique([farmId, userId, role])
  @@index([farmId, role])
  @@index([userId, role])
}

enum MemberActivityModule {
  cheptel
  health
  finance
  stock
  gestation
  collaboration
}

model MemberActivityLog {
  id         String               @id @default(cuid())
  farmId     String
  farm       Farm                 @relation(fields: [farmId], references: [id], onDelete: Cascade)
  memberId   String
  member     FarmMembership       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  module     MemberActivityModule
  action     String
  detail     Json?
  createdAt  DateTime             @default(now())

  @@index([farmId, createdAt])
  @@index([farmId, memberId])
}

enum ChatRoomKind {
  farm
  direct
}

model ChatRoom {
  id        String           @id @default(cuid())
  kind      ChatRoomKind
  farmId    String?          @unique
  farm      Farm?            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  directKey String?          @unique
  title     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  members   ChatRoomMember[]
  messages  ChatMessage[]

  @@index([kind])
}

model ChatRoomMember {
  id     String   @id @default(cuid())
  roomId String
  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

model ChatMessage {
  id           String   @id @default(cuid())
  roomId       String
  room         ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderUserId String
  sender       User     @relation(fields: [senderUserId], references: [id], onDelete: Restrict)
  body         String
  createdAt    DateTime @default(now())

  @@index([roomId, createdAt])
}

/// Alerte / recommandation métier persistée (SmartAlerts — règles serveur).
model SmartAlert {
  id           String             @id @default(cuid())
  farmId       String
  farm         Farm               @relation(fields: [farmId], references: [id], onDelete: Cascade)
  /// Clé stable par règle (ex. `stock-depletion:<feedTypeId>`) pour upsert au recalcul.
  ruleKey      String
  module       SmartAlertModule
  priority     SmartAlertPriority
  title        String
  message      String
  actionRoute  String?
  actionParams Json?
  isRead       Boolean            @default(false)
  readAt       DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([farmId, ruleKey])
  @@index([farmId, priority, isRead])
  @@index([farmId, module])
}

/// Seuils et options notifications SmartAlerts par ferme.
model FarmAlertSettings {
  id                        String   @id @default(cuid())
  farmId                    String   @unique
  farm                      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  /// Seuil taux mortalité mensuel (ex. 5 = 5 %).
  mortalityRateThresholdPct Decimal? @db.Decimal(8, 4)
  /// Seuil solde bas (optionnel ; sinon `FarmFinanceSettings.lowBalanceThreshold`).
  lowBalanceThreshold       Decimal? @db.Decimal(14, 2)
  stockWarningDays          Int      @default(30)
  stockCriticalDays         Int      @default(15)
  pushStock                 Boolean  @default(true)
  pushHealth                Boolean  @default(true)
  pushFinance               Boolean  @default(true)
  pushGestation             Boolean  @default(true)
  pushCheptel               Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

enum ReportPeriodType {
  monthly
  quarterly
  yearly
}

/// Rapport agrégé multi-modules (PDF + snapshot JSON).
model FarmReport {
  id              String           @id @default(cuid())
  farmId          String
  farm            Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  periodType      ReportPeriodType
  periodStart     DateTime
  periodEnd       DateTime
  generatedAt     DateTime         @default(now())
  scoreGlobal     Int
  scoreBreakdown  Json
  dataSnapshot    Json
  pdfUrl          String?
  contentHash     String?
  createdByUserId String?

  @@index([farmId, generatedAt])
}
