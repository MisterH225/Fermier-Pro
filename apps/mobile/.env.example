# Copier vers .env dans ce dossier (non versionne).
# L API Nest doit etre joignable depuis l appareil : emulateur Android -> http://10.0.2.2:3000 ; iOS simulateur -> http://localhost:3000 ; device physique -> IP LAN de ton PC.

# Google OAuth : activer le provider dans Supabase (Authentication → Providers → Google).
# Ajoute l’URL affichée sous « URL de redirection (Supabase) » sur l’écran de connexion
# dans Authentication → URL configuration → Redirect URLs (varie selon Expo Go / dev client / build).

EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Dev : en Metro (__DEV__), le bouton « Explorer l’app — mode démo » est toujours proposé sans variable.
# Pour un build release (aperçu interne sans OTP), décommente :
# EXPO_PUBLIC_AUTH_BYPASS=true

# Dev uniquement : après connexion classique, copie un court instant `session.access_token` (Supabase)
# dans cette variable pour que « mode démo » appelle la vraie API (plus de mocks GET). Ignoré hors __DEV__.
# Ne pas commiter de vrai jeton ; ne pas utiliser sur un build production (risque d’inclusion dans le bundle).
# EXPO_PUBLIC_DEV_BYPASS_API_ACCESS_TOKEN=

# Metro uniquement : forcer les GET authentifiés vers l’API (ignore les réponses factices du mode démo).
# Sans jeton réel ci-dessus, les appels échoueront (401) — utile pour déboguer le réseau.
# EXPO_PUBLIC_DEMO_DISABLE_API_GET_MOCK=true

# Accès collaboratif : base URL HTTPS pour les Universal Link / web fallback
# du QR de partage. Le chemin /invite/<token> doit rediriger vers `fermier-pro://invite/<token>`
# (page web statique). Si vide, le QR encode le schéma direct `fermier-pro://invite/<token>`.
# EXPO_PUBLIC_INVITE_BASE_URL=https://app.fermier-pro.example/invite
