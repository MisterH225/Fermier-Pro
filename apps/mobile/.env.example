# Copier vers .env dans ce dossier (non versionne).
# L API Nest doit etre joignable depuis l appareil : emulateur Android -> http://10.0.2.2:3000 ; iOS simulateur -> http://localhost:3000 ; device physique -> IP LAN de ton PC.

EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Dev : en Metro (__DEV__), le bouton « Explorer l’app — mode démo » est toujours proposé sans variable.
# Pour un build release (aperçu interne sans OTP), décommente :
# EXPO_PUBLIC_AUTH_BYPASS=true
