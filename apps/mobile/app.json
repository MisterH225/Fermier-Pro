{
  "expo": {
    "name": "Fermier Pro",
    "slug": "fermier-pro",
    "scheme": "fermier-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.fermierpro.app",
      "buildNumber": "14",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["fermier-pro"]
          }
        ]
      }
    },
    "android": {
      "package": "com.fermierpro.app",
      "versionCode": 14,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "fermier-pro"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ebb8a3e5-e17a-4a66-ae0a-f7624ab6c12a",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "plugins": [
      "expo-dev-client",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoriser l'accès à la photothèque pour choisir une photo de profil.",
          "cameraPermission": "Autoriser l'accès à la caméra pour prendre une photo de profil."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Autoriser la localisation pour enregistrer la position de votre exploitation."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ebb8a3e5-e17a-4a66-ae0a-f7624ab6c12a"
      },
      "lastOtaRelease": "2026-06-12-marketplace-partners"
    },
    "owner": "misterh225"
  }
}